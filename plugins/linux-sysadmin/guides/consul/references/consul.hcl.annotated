# consul.hcl — Annotated Consul Server Configuration
#
# Location: /etc/consul.d/consul.hcl
# Apply changes: systemctl restart consul  (or `consul reload` for a subset of settings)
# Validate before restart: consul validate /etc/consul.d/
#
# HCL natively supports comments. This file is a working config with annotations;
# strip the comment lines if you prefer a minimal config.

# =============================================================================
# IDENTITY
# =============================================================================

# datacenter: Logical datacenter name for this agent.
# Default: "dc1"
# Change when: you run multiple datacenters and need WAN-federated service
# discovery or prepared queries across them. Must conform to RFC 1035 DNS label
# rules (lowercase, alphanumeric, hyphens).
datacenter = "dc1"

# node_name: Human-readable identifier for this node in the cluster.
# Default: hostname of the machine
# Change when: hostnames are non-descriptive (e.g., cloud instance IDs) or you
# need stable names across re-provisioning. Must be unique within the datacenter.
node_name = "consul-server-1"

# data_dir: Directory where Consul stores all persistent state (Raft log, Serf
# snapshots, registered services, KV data, ACL tokens if persisted).
# Default: none (required — agent will not start without it)
# Use a dedicated volume with adequate IOPS for server agents. Client agents
# store less data but still need a writable directory.
data_dir = "/opt/consul/data"

# log_level: Verbosity of Consul's own log output.
# Default: "INFO"
# Options: TRACE, DEBUG, INFO, WARN, ERROR
# Change when: debugging cluster issues (TRACE/DEBUG) or reducing log noise in
# production (WARN). Can also be changed at runtime with `consul monitor`.
log_level = "INFO"

# =============================================================================
# NETWORKING
# =============================================================================

# bind_addr: Address used for internal cluster communication (Serf gossip, Raft
# RPC). Every other agent in the cluster must be able to reach this address.
# Default: "0.0.0.0" (binds to all interfaces)
# Change when: the host has multiple NICs and you need Consul to use a specific
# one. Use Go template syntax for dynamic selection:
#   bind_addr = "{{ GetInterfaceIP \"eth0\" }}"
bind_addr = "0.0.0.0"

# client_addr: Address for client-facing interfaces: HTTP API, DNS, and gRPC.
# Default: "127.0.0.1" (loopback only)
# Change when: you need the API/DNS accessible from other hosts. Set to
# "0.0.0.0" to listen on all interfaces, but restrict access via ACLs and
# firewall rules. Never expose 0.0.0.0 without ACLs enabled.
client_addr = "127.0.0.1"

# =============================================================================
# SERVER MODE
# =============================================================================

# server: Whether this agent runs as a Consul server (participates in Raft
# consensus, stores all cluster state) or a client (lightweight forwarder).
# Default: false (client mode)
# Production clusters need 3 or 5 servers. Never use an even number; Raft
# consensus requires a strict majority.
server = true

# bootstrap_expect: Number of server agents expected in the datacenter. Consul
# delays leader election until this many servers have joined, preventing a
# single-node cluster from bootstrapping prematurely.
# Default: 0 (disabled; single-server dev mode)
# Set to 3 or 5 for production. All servers in the datacenter must use the same
# value. After the cluster bootstraps, this setting has no further effect.
bootstrap_expect = 3

# retry_join: List of addresses to contact when this agent starts, to discover
# and join an existing cluster. Consul retries until successful.
# Default: [] (no automatic join)
# Accepts IP addresses, DNS names, or cloud auto-join strings
# (e.g., "provider=aws tag_key=consul tag_value=server").
retry_join = ["10.0.0.11", "10.0.0.12", "10.0.0.13"]

# =============================================================================
# GOSSIP ENCRYPTION
# =============================================================================

# encrypt: 32-byte Base64-encoded key for Serf gossip encryption. All agents in
# the cluster (servers and clients) must share the same key.
# Default: none (gossip traffic is unencrypted)
# Generate with: consul keygen
# Change when: always set this before first deployment. Retrofitting encryption
# into an existing cluster requires a multi-step key rotation process (install
# new key, make it primary, remove old key). See Consul docs for the procedure.
encrypt = "pUqJrVyVRj5jsiYEkM/tFQYfWyJIv4s3XkvDwy7u5Sk="

# =============================================================================
# UI CONFIGURATION
# =============================================================================

ui_config {
  # enabled: Activate the built-in web UI served on the HTTP/HTTPS port.
  # Default: false
  # The UI provides a visual dashboard for services, nodes, KV, ACLs, and
  # intentions. Enable on one or more servers; access at http://<client_addr>:8500/ui.
  # In production, restrict access via ACLs or a reverse proxy.
  enabled = true

  # content_path: URL prefix for the UI, useful when proxying Consul behind a
  # path-based reverse proxy (e.g., /consul/ui/).
  # Default: "/ui/"
  # content_path = "/ui/"
}

# =============================================================================
# PORTS
# =============================================================================

ports {
  # http: HTTP API and UI.
  # Default: 8500
  # Set to -1 to disable HTTP entirely (use HTTPS only).
  http = 8500

  # https: HTTPS API and UI (requires TLS configuration below).
  # Default: -1 (disabled)
  # Enable by setting to 8501 and configuring the tls stanza.
  https = -1

  # dns: DNS interface for service discovery queries in the .consul domain.
  # Default: 8600 (TCP and UDP)
  # Set to -1 to disable. Forward .consul queries from your system resolver
  # (systemd-resolved, dnsmasq, unbound) to this port.
  dns = 8600

  # grpc: Plaintext gRPC API (used by Consul Dataplane, Envoy xDS).
  # Default: -1 (disabled)
  # Enable by setting to 8502 when using Consul Dataplane or Envoy proxies
  # without TLS.
  grpc = -1

  # grpc_tls: TLS-encrypted gRPC API.
  # Default: 8503 (enabled on servers by default)
  # Primary interface for Consul Dataplane and Envoy xDS in production.
  grpc_tls = 8503

  # serf_lan: Serf LAN gossip port for intra-datacenter communication.
  # Default: 8301 (TCP and UDP)
  # All agents (servers and clients) must be able to reach each other on this
  # port. Rarely changed.
  serf_lan = 8301

  # serf_wan: Serf WAN gossip port for cross-datacenter server communication.
  # Default: 8302 (TCP and UDP)
  # Only servers use this port. Set to -1 to disable WAN federation.
  serf_wan = 8302

  # server: Server RPC port for Raft consensus and forwarded client RPCs.
  # Default: 8300
  # Only servers listen on this port. Clients connect to it for RPC forwarding.
  server = 8300
}

# =============================================================================
# ACL (ACCESS CONTROL LIST)
# =============================================================================

acl {
  # enabled: Turn on the ACL system. Without this, all operations are
  # unrestricted regardless of other ACL settings.
  # Default: false
  # Enable before first production deployment. Rolling out ACLs on an existing
  # cluster requires careful sequencing: enable with default_policy = "allow"
  # first, create tokens, then switch to "deny".
  enabled = true

  # default_policy: What happens when no ACL rule matches a request.
  # Default: "allow"
  # Options: "allow" (denylist model — everything permitted unless blocked),
  #          "deny"  (allowlist model — everything blocked unless permitted)
  # Production clusters should use "deny". Start with "allow" during initial
  # token creation to avoid locking yourself out.
  default_policy = "deny"

  # enable_token_persistence: Whether tokens set via the API are persisted to
  # disk so they survive agent restarts.
  # Default: false
  # Set to true on all agents. Without this, API-configured tokens (including
  # the agent token) are lost on restart and must be re-applied.
  enable_token_persistence = true

  # down_policy: Behavior when the agent cannot reach the ACL datacenter or
  # leader to resolve tokens.
  # Default: "extend-cache"
  # Options: "allow" (permit all), "deny" (block all), "extend-cache" (use
  # cached ACL results even if expired), "async-cache" (like extend-cache but
  # updates asynchronously in the background)
  # "extend-cache" is the safest default; it prevents an ACL outage from
  # cascading into a service outage.
  down_policy = "extend-cache"

  tokens {
    # initial_management: A well-known secret ID for the initial management
    # token, created automatically when the first server becomes leader.
    # Default: none
    # Only applies to servers in the primary datacenter. Replaces the old
    # `consul acl bootstrap` one-shot workflow when set. Store securely.
    # initial_management = "<uuid>"

    # agent: Token used by the agent for internal operations (registering
    # itself, syncing checks). Must have node:write for this node's name.
    # Default: uses the default token if unset
    # agent = "<uuid>"

    # default: Fallback token attached to requests that don't include one.
    # Default: anonymous token (minimal permissions)
    # default = "<uuid>"

    # agent_recovery: Emergency access token that works even when servers are
    # unreachable. Grants access to agent-level endpoints only.
    # Default: none
    # Set this before you need it; during an outage is too late.
    # agent_recovery = "<uuid>"
  }
}

# =============================================================================
# CONNECT (SERVICE MESH)
# =============================================================================

connect {
  # enabled: Activate Consul's service mesh (formerly "Consul Connect").
  # Enables mTLS between services via sidecar proxies and intention-based
  # authorization.
  # Default: false
  # Enabling Connect starts a built-in CA. Each registered service can get an
  # Envoy sidecar proxy for transparent mTLS. Intentions replace firewall rules
  # for service-to-service authorization.
  enabled = true

  # ca_provider: Certificate authority backend for issuing service mesh
  # certificates.
  # Default: "consul" (built-in CA)
  # Options: "consul" (built-in), "vault" (HashiCorp Vault PKI backend),
  #          "aws-pca" (AWS Private Certificate Authority)
  # The built-in CA requires no external dependencies and auto-generates a root
  # certificate and key. Use Vault for centralized PKI management.
  ca_provider = "consul"

  ca_config {
    # leaf_cert_ttl: Lifetime of leaf certificates issued to service proxies.
    # Default: "72h"
    # Shorter TTLs reduce blast radius of a compromised certificate but increase
    # CA signing load. The mesh renews certificates automatically before expiry.
    leaf_cert_ttl = "72h"

    # root_cert_ttl: Lifetime of the root CA certificate.
    # Default: "87600h" (10 years)
    # Only applies when the built-in CA generates a new root. After the root is
    # created, changing this requires a CA rotation.
    root_cert_ttl = "87600h"

    # csr_max_per_second: Rate limit on certificate signing requests.
    # Default: 50
    # Prevents CA rotation storms from overwhelming server CPU. Set to 0 to
    # disable rate limiting (not recommended for large clusters).
    csr_max_per_second = 50

    # private_key_type: Key algorithm for generated certificates.
    # Default: "ec"
    # Options: "ec" (ECDSA, faster and smaller), "rsa" (wider compatibility)
    private_key_type = "ec"

    # private_key_bits: Key size. For EC: 224, 256, 384, 521. For RSA: 2048, 4096.
    # Default: 256 (for EC)
    private_key_bits = 256
  }
}

# =============================================================================
# TLS
# =============================================================================

tls {
  defaults {
    # ca_file: PEM-encoded CA certificate used to verify both incoming and
    # outgoing TLS connections across all interfaces.
    # Default: none
    ca_file = "/opt/consul/tls/consul-agent-ca.pem"

    # cert_file: PEM-encoded certificate presented by this agent.
    # Default: none
    # Must be signed by the CA in ca_file. Generate with `consul tls cert create`.
    cert_file = "/opt/consul/tls/dc1-server-consul-0.pem"

    # key_file: Private key corresponding to cert_file.
    # Default: none
    key_file = "/opt/consul/tls/dc1-server-consul-0-key.pem"

    # tls_min_version: Minimum TLS protocol version accepted.
    # Default: "TLSv1_2"
    # Options: "TLSv1_0", "TLSv1_1", "TLSv1_2", "TLSv1_3"
    # TLSv1.2 is the minimum safe choice; use TLSv1.3 if all agents support it.
    tls_min_version = "TLSv1_2"

    # verify_incoming: Require all inbound connections to present a valid TLS
    # client certificate signed by the CA.
    # Default: false
    # Enable for mutual TLS (mTLS). Prevents unauthorized agents from joining
    # the cluster.
    verify_incoming = true

    # verify_outgoing: Require all outbound connections to use TLS with
    # certificate verification.
    # Default: false
    # Enable on all agents. Once enabled on servers, clients that don't present
    # valid certificates will be rejected.
    verify_outgoing = true
  }

  internal_rpc {
    # verify_server_hostname: Validate that the server certificate's SAN matches
    # the pattern server.<datacenter>.<domain>.
    # Default: false
    # Prevents a compromised client agent from impersonating a server. Always
    # enable in production alongside verify_incoming and verify_outgoing.
    verify_server_hostname = true
  }

  # https and grpc blocks accept the same parameters as defaults, allowing
  # per-interface TLS overrides (e.g., different certificates for the HTTPS API
  # than for internal RPC).
  # https {
  #   ca_file   = "/opt/consul/tls/external-ca.pem"
  #   cert_file = "/opt/consul/tls/api-cert.pem"
  #   key_file  = "/opt/consul/tls/api-key.pem"
  # }
}

# =============================================================================
# PERFORMANCE
# =============================================================================

performance {
  # raft_multiplier: Scaling factor for Raft timing parameters (heartbeat,
  # election timeout, leader lease). Higher values make Raft more tolerant of
  # network latency but slower to detect failures.
  # Default: 5 (relaxed timing for development/low-spec environments)
  # Set to 1 for production on dedicated servers with reliable networks. The
  # difference is significant: at 1, leader failure is detected in ~3s; at 5,
  # it can take ~15s.
  raft_multiplier = 1

  # leave_drain_time: How long a server dwells during a graceful leave to drain
  # in-flight RPCs.
  # Default: "5s"
  # Increase if clients experience transient RPC errors during rolling restarts.
  leave_drain_time = "5s"

  # rpc_hold_timeout: How long a client or server retries internal RPC requests
  # during a leader election before returning an error.
  # Default: "7s"
  # Should be slightly longer than the expected leader election duration
  # (controlled by raft_multiplier).
  rpc_hold_timeout = "7s"
}

# =============================================================================
# AUTOPILOT
# =============================================================================

autopilot {
  # cleanup_dead_servers: Automatically remove failed servers from the Raft peer
  # set so they don't count against quorum.
  # Default: true
  # Disable only if you want manual control over peer removal (e.g., to
  # investigate failures before removing nodes).
  cleanup_dead_servers = true

  # last_contact_threshold: Maximum time since a server's last contact with the
  # leader before autopilot considers it unhealthy.
  # Default: "200ms"
  # Increase in high-latency environments (e.g., cross-region clusters), but
  # be aware that higher values delay detection of truly failed servers.
  last_contact_threshold = "200ms"

  # max_trailing_logs: Maximum number of Raft log entries a server can trail the
  # leader by while still being considered healthy.
  # Default: 250
  # A server that falls further behind is marked unhealthy and won't receive
  # leadership. Increase if servers have slow disks or large write volumes.
  max_trailing_logs = 250

  # server_stabilization_time: Duration a new server must remain healthy before
  # autopilot promotes it to a voting member.
  # Default: "10s"
  # Prevents a flapping server from rapidly joining and leaving the voter set.
  # Increase for environments where servers take longer to stabilize after boot.
  server_stabilization_time = "10s"

  # min_quorum: Minimum number of voting servers autopilot will maintain. It
  # will not remove servers if doing so would drop below this threshold.
  # Default: 0 (no minimum enforced)
  # Set to your bootstrap_expect value (e.g., 3) to prevent autopilot from
  # reducing the cluster below quorum during cascading failures.
  min_quorum = 0
}

## Deployment Notes

# Generate TLS certificates:
#   consul tls ca create
#   consul tls cert create -server -dc dc1
#   consul tls cert create -client -dc dc1

# Generate gossip encryption key:
#   consul keygen

# Validate configuration:
#   consul validate /etc/consul.d/

# Bootstrap a new cluster:
# 1. Deploy this config to 3 (or 5) servers with matching bootstrap_expect
# 2. Start all servers: systemctl start consul
# 3. Verify: consul members (should show all servers)
# 4. Bootstrap ACLs: consul acl bootstrap
# 5. Store the bootstrap token securely — it cannot be regenerated

# Rotate gossip encryption key (zero-downtime):
# 1. consul keyring -install <new-key>   (on any node)
# 2. consul keyring -use <new-key>       (make it primary)
# 3. consul keyring -remove <old-key>    (clean up)
