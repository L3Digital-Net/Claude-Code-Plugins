# Annotated vault.hcl — Production Server Configuration
# Each directive includes: what it does, default value, and when to change it.
# Vault uses HCL (or JSON) for configuration.
#
# After changes: sudo systemctl restart vault
# Config location: /etc/vault.d/vault.hcl (package install default)
# Env var overrides: VAULT_ADDR, VAULT_TOKEN, VAULT_LOG_LEVEL, etc.
# Verify config syntax: vault server -config=/etc/vault.d/vault.hcl -dev (will fail
#   on missing certs, but catches HCL parse errors)

# ──────────────────────────────────────────────────────────────────────────────
# Core settings
# ──────────────────────────────────────────────────────────────────────────────

# Enable the web UI at /ui. Requires a valid token to access.
# Default: false  |  Change when: you want browser-based management.
ui = true

# Full URL clients should use to reach this node's API.
# Required for HA clusters so standbys can redirect clients to the active node.
# Default: ""  |  Change when: running HA or any multi-node setup.
api_addr = "https://vault.example.com:8200"

# Address this node advertises for cluster-internal traffic (Raft, forwarding).
# Must be routable from all other cluster nodes. Never use 127.0.0.1 here.
# Default: ""  |  Change when: running any multi-node cluster.
cluster_addr = "https://10.0.1.10:8201"

# Prevents Vault memory from being swapped to disk. Recommended for production.
# Requires CAP_IPC_LOCK capability: setcap cap_ipc_lock=+ep $(which vault)
# Default: must be explicitly set with integrated storage.
# Set to true only if running in a container without the capability, or if swap
# is encrypted. The systemd unit from the package sets the capability automatically.
disable_mlock = false

# Default lease TTL for tokens and secrets when not specified by the auth method
# or secrets engine. 768h = 32 days.
# Default: "768h"  |  Change when: you want shorter default leases for security.
#default_lease_ttl = "768h"

# Hard ceiling on any lease TTL. Auth methods and secrets engines can set their
# own max, but never above this value.
# Default: "768h"  |  Change when: you need longer-lived certs or credentials.
#max_lease_ttl = "768h"

# Log verbosity. SIGHUP changes this at runtime without restart.
# Options: trace, debug, info, warn, error
# Default: "info"  |  Change when: debugging or reducing log noise.
#log_level = "info"

# Human-readable cluster name. Shows in the UI and status output.
# Default: auto-generated  |  Change when: you operate multiple clusters.
#cluster_name = "vault-prod"

# ──────────────────────────────────────────────────────────────────────────────
# Listener — how clients connect to the API
# ──────────────────────────────────────────────────────────────────────────────

listener "tcp" {
  # IP and port to bind. 0.0.0.0 listens on all interfaces.
  # Default: "127.0.0.1:8200"  |  Change when: clients connect from other hosts.
  address = "0.0.0.0:8200"

  # Cluster traffic port. Used for Raft replication and request forwarding.
  # Default: one above the API port (8201)  |  Rarely needs changing.
  cluster_address = "0.0.0.0:8201"

  # TLS certificate (full chain) and private key. Vault expects TLS by default;
  # setting tls_disable = true is only appropriate for dev/testing behind a proxy.
  tls_cert_file = "/etc/vault.d/tls/vault-cert.pem"
  tls_key_file  = "/etc/vault.d/tls/vault-key.pem"

  # Disable TLS entirely. NEVER do this in production without a TLS-terminating
  # proxy in front of Vault.
  # Default: false  |  Change when: TLS is handled by a load balancer or sidecar.
  #tls_disable = false

  # Minimum TLS version. TLS 1.2 is the floor for most compliance regimes.
  # Default: "tls12"  |  Change when: you need to enforce TLS 1.3 only.
  #tls_min_version = "tls12"

  # Client certificate verification for mTLS. Options: "", "require_and_verify".
  # Default: ""  |  Change when: enforcing mutual TLS on the API.
  #tls_require_and_verify_client_cert = ""
}

# ──────────────────────────────────────────────────────────────────────────────
# Storage — where encrypted data lives
# ──────────────────────────────────────────────────────────────────────────────

# Raft integrated storage is the recommended backend (replaces Consul).
# Provides built-in HA, snapshots, and no external dependency.
storage "raft" {
  # Filesystem path for Raft data. Must be on fast, reliable storage (SSD).
  # The vault user must own this directory.
  # Default: none (required)  |  Override: VAULT_RAFT_PATH env var.
  path = "/opt/vault/data"

  # Unique identifier for this node within the cluster.
  # Default: auto-generated  |  Override: VAULT_RAFT_NODE_ID env var.
  # Set explicitly when you need deterministic node names for monitoring.
  node_id = "vault-node-1"

  # Multiplier for Raft timing (leader election, heartbeat). Higher values
  # tolerate more latency but detect failures slower.
  # Default: 0 (uses Raft library default of 5)  |  Range: 1-10.
  # Set to 1 for low-latency same-datacenter clusters.
  #performance_multiplier = 5

  # Peers to attempt joining on startup. List all other cluster members.
  # Vault retries until successful, so ordering doesn't matter.
  # Omit retry_join on the very first node during initial cluster bootstrap.
  retry_join {
    leader_api_addr         = "https://10.0.1.11:8200"
    leader_ca_cert_file     = "/etc/vault.d/tls/ca-cert.pem"
    #leader_client_cert_file = "/etc/vault.d/tls/vault-cert.pem"
    #leader_client_key_file  = "/etc/vault.d/tls/vault-key.pem"
  }

  retry_join {
    leader_api_addr         = "https://10.0.1.12:8200"
    leader_ca_cert_file     = "/etc/vault.d/tls/ca-cert.pem"
  }
}

# ──────────────────────────────────────────────────────────────────────────────
# Seal — how the root key is protected
# ──────────────────────────────────────────────────────────────────────────────

# Default: Shamir's Secret Sharing (no seal stanza needed).
# Uncomment ONE of the following blocks for auto-unseal.

# --- AWS KMS auto-unseal ---
# Vault uses the KMS key to encrypt/decrypt its root key on startup.
# Recovery keys replace unseal keys; they CANNOT decrypt the root key if
# the KMS key is lost.
# Credentials: prefer IAM role or env vars (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# over hardcoded values here.
#seal "awskms" {
#  region     = "us-east-1"
#  kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/abcd1234-..."
#  # access_key and secret_key — omit when using instance profile / IAM role.
#  #access_key = "AKIA..."
#  #secret_key = "..."
#  # Custom endpoint for VPC endpoints or FIPS.
#  #endpoint   = "https://vpce-...kms.us-east-1.vpce.amazonaws.com"
#}

# --- Transit auto-unseal (Vault unsealing Vault) ---
# A separate "unsealer" Vault cluster provides the transit key.
# The token needs encrypt + decrypt on transit/encrypt/<key> and transit/decrypt/<key>.
# Strongly recommended to set token via VAULT_TRANSIT_SEAL_TOKEN env var.
#seal "transit" {
#  address     = "https://unsealer-vault.example.com:8200"
#  token       = "s.xxxxxxx"          # prefer env var VAULT_TRANSIT_SEAL_TOKEN
#  key_name    = "vault-autounseal"
#  mount_path  = "transit/"
#  #namespace  = "admin/"             # Enterprise namespaces only
#  tls_ca_cert = "/etc/vault.d/tls/unsealer-ca.pem"
#}

# ──────────────────────────────────────────────────────────────────────────────
# Telemetry — metrics emission for monitoring
# ──────────────────────────────────────────────────────────────────────────────

telemetry {
  # Prometheus metrics endpoint at /v1/sys/metrics (requires a valid token with
  # read on sys/metrics, or configure unauthenticated_metrics_access = true).
  prometheus_retention_time = "30s"
  disable_hostname         = true

  # StatsD / Statsite push
  #statsite_address = "127.0.0.1:8125"
  #statsd_address   = "127.0.0.1:8125"
}

# ──────────────────────────────────────────────────────────────────────────────
# Service registration (optional)
# ──────────────────────────────────────────────────────────────────────────────

# Register Vault with Consul for service discovery (separate from storage).
# Not needed if clients use a load balancer or DNS to find Vault.
#service_registration "consul" {
#  address = "127.0.0.1:8500"
#}

# Register with Kubernetes service catalog.
#service_registration "kubernetes" {}
