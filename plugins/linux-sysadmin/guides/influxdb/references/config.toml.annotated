# Annotated InfluxDB Configuration
# Each directive includes: what it does, default value, and when to change it.
#
# This file covers BOTH InfluxDB v2 (OSS) and InfluxDB 3 (Core/Enterprise).
# Options are labeled [v2] or [v3] where they differ. Unlabeled options are
# shared or conceptually equivalent across versions.
#
# InfluxDB v2: uses a TOML config file (config.toml). Place at the working
#   directory or set INFLUXD_CONFIG_PATH=/etc/influxdb/config.toml.
#   After changes: sudo systemctl restart influxdb
#
# InfluxDB 3: has NO config file. All configuration is via CLI flags or
#   environment variables (prefixed INFLUXDB3_). Flags take precedence over
#   env vars. For systemd, put flags in the unit file or an override.
#   After changes: sudo systemctl restart influxdb3-core
#
# The TOML format below applies to v2. For v3, the equivalent flag name and
# environment variable are noted in each section.

# ===========================================================================
# STORAGE PATHS
# ===========================================================================

# [v2] Path to the BoltDB database. Stores organizations, users, dashboards,
# and other metadata (not time series data).
# Default: ~/.influxdbv2/influxd.bolt  |  Env: INFLUXD_BOLT_PATH
# Change when: you want metadata on a specific disk or partition.
bolt-path = "/var/lib/influxdb2/influxd.bolt"

# [v2] Path to the TSM storage engine directory. This is where all time
# series data (TSM files, WAL, indexes) lives. Put this on fast storage.
# Default: ~/.influxdbv2/engine  |  Env: INFLUXD_ENGINE_PATH
# Change when: separating data from metadata for performance or backup.
engine-path = "/var/lib/influxdb2/engine"

# [v3] Local data directory for WAL, snapshots, and metadata. InfluxDB 3
# does not use BoltDB or TSM; it stores data as Parquet files.
# Flag: --data-dir  |  Env: INFLUXDB3_DATA_DIR  |  Default: ~/.influxdb
# Change when: you want data on a specific disk or volume mount.
# (v3 only, not a TOML key)

# ===========================================================================
# HTTP / API
# ===========================================================================

# [v2] Bind address for the HTTP API and UI. Format: "host:port".
# An empty host (":8086") binds to all interfaces.
# Default: ":8086"  |  Env: INFLUXD_HTTP_BIND_ADDRESS
# Change when: restricting to a specific interface or using a non-standard port.
http-bind-address = ":8086"

# [v3] Bind address for the HTTP API.
# Flag: --http-bind  |  Env: INFLUXDB3_HTTP_BIND  |  Default: "0.0.0.0:8181"
# Note: v3 uses port 8181 by default (not 8086).
# (v3 only, not a TOML key)

# ===========================================================================
# TELEMETRY
# ===========================================================================

# [v2] Disable sending anonymous usage statistics to InfluxData. Set true
# in air-gapped or privacy-sensitive environments.
# Default: false  |  Env: INFLUXD_REPORTING_DISABLED
reporting-disabled = true

# [v3] Disable telemetry upload.
# Flag: --telemetry-disable-upload  |  Env: INFLUXDB3_TELEMETRY_DISABLE_UPLOAD
# Default: false
# (v3 only, not a TOML key)

# ===========================================================================
# STORAGE — CACHE
# ===========================================================================

# [v2] Maximum bytes the in-memory shard cache can use before it begins
# rejecting writes. Each shard (time partition) has its own cache.
# Default: 1073741824 (1 GiB)  |  Env: INFLUXD_STORAGE_CACHE_MAX_MEMORY_SIZE
# Change when: high write throughput needs a larger cache, or memory is
#   constrained and you need to shrink it.
storage-cache-max-memory-size = 1073741824

# [v2] Maximum bytes for cache snapshots during compaction. When a shard
# cache snapshot exceeds this, the snapshot is split.
# Default: 26214400 (25 MiB)  |  Env: INFLUXD_STORAGE_CACHE_SNAPSHOT_MEMORY_SIZE
# Change when: compaction is slow because snapshots are too large.
# storage-cache-snapshot-memory-size = 26214400

# [v2] Duration a shard's cache must be inactive before triggering a
# snapshot to a TSM file. Helps flush cold (rarely written) shards.
# Default: "10m0s"  |  Env: INFLUXD_STORAGE_CACHE_SNAPSHOT_WRITE_COLD_DURATION
# Change when: you want cold shards flushed faster or slower.
# storage-cache-snapshot-write-cold-duration = "10m0s"

# ===========================================================================
# STORAGE — WAL
# ===========================================================================

# [v2] Duration to wait before fsyncing a WAL write. A value of "0s" means
# every write is fsynced immediately (safest, slowest). Increasing this
# batches multiple writes into a single fsync, improving throughput at the
# risk of losing unflushed writes on power loss.
# Default: "0s"  |  Env: INFLUXD_STORAGE_WAL_FSYNC_DELAY
# Change when: write throughput is limited by fsync latency, and you accept
#   the risk of losing a small window of data on crash.
storage-wal-fsync-delay = "0s"

# [v2] Maximum concurrent WAL writes.
# Default: 0 (CPUs x 2)  |  Env: INFLUXD_STORAGE_WAL_MAX_CONCURRENT_WRITES
# Change when: reducing write contention on resource-constrained systems.
# storage-wal-max-concurrent-writes = 0

# [v2] Maximum delay before a WAL write is rejected when the WAL is busy.
# Default: "10m"  |  Env: INFLUXD_STORAGE_WAL_MAX_WRITE_DELAY
# Change when: you'd rather reject writes quickly than queue them for minutes.
# storage-wal-max-write-delay = "10m"

# [v2] Maximum time to wait for a write operation to complete.
# Default: "10s"  |  Env: INFLUXD_STORAGE_WRITE_TIMEOUT
# Change when: large batch writes need more time to complete.
# storage-write-timeout = "10s"

# [v3] WAL flush interval. Controls how often buffered writes are flushed
# to the WAL.
# Flag: --wal-flush-interval  |  Env: INFLUXDB3_WAL_FLUSH_INTERVAL
# (v3 only, not a TOML key)

# [v3] Maximum WAL write buffer size before forcing a flush.
# Flag: --wal-max-write-buffer-size  |  Env: INFLUXDB3_WAL_MAX_WRITE_BUFFER_SIZE
# (v3 only, not a TOML key)

# ===========================================================================
# STORAGE — COMPACTION
# ===========================================================================

# [v2] Duration a shard must be "cold" (no writes) before a full compaction
# is triggered. Full compaction rewrites all TSM files into optimal layout.
# Default: "4h0m0s"  |  Env: INFLUXD_STORAGE_COMPACT_FULL_WRITE_COLD_DURATION
# Change when: you want compaction sooner on idle shards, or you want to
#   delay it to reduce I/O during business hours.
# storage-compact-full-write-cold-duration = "4h0m0s"

# [v2] Maximum throughput for compaction in bytes per second. Limits the
# I/O impact of compaction on concurrent queries.
# Default: 50331648 (48 MiB/s)  |  Env: INFLUXD_STORAGE_COMPACT_THROUGHPUT_BURST
# Change when: compaction starves queries (lower it) or takes too long (raise it).
# storage-compact-throughput-burst = 50331648

# [v2] Maximum number of concurrent compaction operations.
# Default: 0 (50% of GOMAXPROCS)  |  Env: INFLUXD_STORAGE_MAX_CONCURRENT_COMPACTIONS
# Change when: compaction I/O is too aggressive or not aggressive enough.
# storage-max-concurrent-compactions = 0

# ===========================================================================
# RETENTION
# ===========================================================================

# [v2] How often the retention policy enforcement service runs. It checks
# each bucket's retention period and deletes expired shard groups.
# Default: "30m0s"  |  Env: INFLUXD_STORAGE_RETENTION_CHECK_INTERVAL
# Change when: you need expired data removed more quickly (e.g., "10m")
#   or want to reduce background work on a quiet server.
storage-retention-check-interval = "30m0s"

# [v3] How often retention enforcement runs.
# Flag: --retention-check-interval  |  Env: INFLUXDB3_RETENTION_CHECK_INTERVAL
# Default: "30m"
# (v3 only, not a TOML key)

# [v3] Default retention duration for databases when not explicitly set.
# Flag: --hard-delete-default-duration  |  Env: INFLUXDB3_HARD_DELETE_DEFAULT_DURATION
# Default: 90 days
# (v3 only, not a TOML key)

# ===========================================================================
# LOGGING
# ===========================================================================

# [v2] Minimum log level. Controls verbosity of the influxd process.
# Valid values: debug, info, error
# Default: "info"  |  Env: INFLUXD_LOG_LEVEL
# Change when: debugging issues (use "debug") or reducing log noise
#   in stable production (use "error").
log-level = "info"

# [v3] Log filter expression. Supports per-module filtering with Rust-style
# env_logger syntax (e.g., "info,hyper=warn,influxdb3_write=debug").
# Flag: --log-filter  |  Env: LOG_FILTER  |  Default: "info"
# (v3 only, not a TOML key)

# [v3] Log output format.
# Flag: --log-format  |  Env: INFLUXDB3_LOG_FORMAT  |  Default: "text"
# Valid values: "text", "json"
# Change when: shipping logs to a structured log aggregator.
# (v3 only, not a TOML key)

# [v3] Where logs are written.
# Flag: --log-destination  |  Env: INFLUXDB3_LOG_DESTINATION  |  Default: "stdout"
# (v3 only, not a TOML key)

# ===========================================================================
# TLS
# ===========================================================================

# [v2] Path to PEM-encoded TLS certificate. Both tls-cert and tls-key must
# be set together to enable HTTPS. When set, InfluxDB serves HTTPS only;
# there is no mixed HTTP+HTTPS mode.
# Default: "" (TLS disabled)  |  Env: INFLUXD_TLS_CERT
# Change when: enabling HTTPS for the API and UI.
# tls-cert = "/etc/influxdb/tls/server.crt"

# [v2] Path to PEM-encoded TLS private key. Must be set with tls-cert.
# Default: "" (TLS disabled)  |  Env: INFLUXD_TLS_KEY
# tls-key = "/etc/influxdb/tls/server.key"

# [v2] Minimum TLS version the server will negotiate.
# Default: "1.2"  |  Env: INFLUXD_TLS_MIN_VERSION
# Valid values: "1.0", "1.1", "1.2", "1.3"
# Change when: enforcing TLS 1.3 only, or supporting legacy clients on 1.0/1.1
#   (not recommended).
# tls-min-version = "1.2"

# [v2] Restrict accepted TLS ciphers to a secure subset. When true, only
# six cipher suites are allowed (ECDHE variants with AES-GCM and
# ChaCha20-Poly1305).
# Default: false  |  Env: INFLUXD_TLS_STRICT_CIPHERS
# Change when: compliance requires a restricted cipher list.
# tls-strict-ciphers = false

# [v3] TLS certificate and key. Same concept as v2.
# Flag: --tls-cert  |  Env: INFLUXDB3_TLS_CERT
# Flag: --tls-key   |  Env: INFLUXDB3_TLS_KEY
# (v3 only, not TOML keys)

# [v3] Minimum TLS version.
# Flag: --tls-minimum-version  |  Env: INFLUXDB3_TLS_MINIMUM_VERSION
# Default: "1.2"
# (v3 only, not a TOML key)

# ===========================================================================
# QUERY (v2 only)
# ===========================================================================

# [v2] Maximum number of queries that can execute concurrently.
# Default: 0 (unlimited)  |  Env: INFLUXD_QUERY_CONCURRENCY
# Change when: you need to prevent a flood of queries from exhausting resources.
# query-concurrency = 0

# [v2] Maximum number of queries waiting in the queue when concurrency
# limit is reached. Excess queries are rejected immediately.
# Default: 0 (unlimited)  |  Env: INFLUXD_QUERY_QUEUE_SIZE
# query-queue-size = 0

# [v2] Maximum bytes of memory a single query can use.
# Default: 0 (unlimited)  |  Env: INFLUXD_QUERY_MEMORY_BYTES
# Change when: a single expensive query has caused OOM kills.
# query-memory-bytes = 0

# ===========================================================================
# QUERY AND CACHE (v3 only)
# ===========================================================================

# [v3] Memory pool for query execution across all concurrent queries.
# Flag: --exec-mem-pool-bytes  |  Env: INFLUXDB3_EXEC_MEM_POOL_BYTES
# Change when: large analytical queries get rejected due to memory limits.
# (v3 only, not a TOML key)

# [v3] Number of DataFusion query execution threads.
# Flag: --datafusion-num-threads  |  Env: INFLUXDB3_DATAFUSION_NUM_THREADS
# Default: number of CPUs
# (v3 only, not a TOML key)

# [v3] Disable the in-memory Parquet cache. Disabling reduces memory usage
# but increases read latency.
# Flag: --disable-parquet-mem-cache  |  Env: INFLUXDB3_DISABLE_PARQUET_MEM_CACHE
# Default: false
# (v3 only, not a TOML key)

# [v3] Maximum memory for the Parquet file cache.
# Flag: --parquet-mem-cache-size  |  Env: INFLUXDB3_PARQUET_MEM_CACHE_SIZE
# Change when: read-heavy workloads benefit from a larger cache, or memory
#   is constrained.
# (v3 only, not a TOML key)

# ===========================================================================
# AUTHENTICATION (v3 only)
# ===========================================================================

# [v3] Disable authentication entirely. Only for development.
# Flag: --without-auth  |  Env: INFLUXDB3_WITHOUT_AUTH  |  Default: false
# (v3 only, not a TOML key)

# [v3] Path to a file containing the admin token. Alternative to generating
# one at runtime with `influxdb3 create token --admin`.
# Flag: --admin-token-file  |  Env: INFLUXDB3_ADMIN_TOKEN_FILE
# (v3 only, not a TOML key)

# ===========================================================================
# OBJECT STORE (v3 only)
# ===========================================================================

# [v3] Storage backend type. InfluxDB 3 persists data as Parquet files.
# Flag: --object-store  |  Env: INFLUXDB3_OBJECT_STORE  |  Default: "file"
# Valid values: file, memory, s3 (or aws), azure, google
#   "file" writes Parquet to a local directory.
#   "memory" is for testing only (data lost on restart).
#   "s3", "azure", "google" for cloud object storage.
# (v3 only, not a TOML key)

# [v3] Unique server node identifier. Must be unique across all servers
# sharing the same object store.
# Flag: --node-id  |  Env: INFLUXDB3_NODE_ID  |  Default: auto-generated
# Change when: you want deterministic, meaningful node names for monitoring.
# (v3 only, not a TOML key)

# ===========================================================================
# VERSION DIFFERENCES SUMMARY
# ===========================================================================
#
# | Feature                  | InfluxDB v2 (OSS)         | InfluxDB 3 (Core)          |
# |--------------------------|---------------------------|----------------------------|
# | Config format            | TOML file (config.toml)   | CLI flags / env vars only  |
# | Default API port         | 8086                      | 8181                       |
# | Storage engine           | TSM (Time-Structured Merge)| Apache Parquet + DataFusion|
# | Data model               | Buckets + measurements    | Databases + tables         |
# | Query language           | Flux + InfluxQL           | SQL (primary) + InfluxQL   |
# | Write compatibility      | /api/v2/write             | /api/v3/write_lp + v2 compat|
# | Retention                | Per-bucket                | Per-database               |
# | Authentication           | Token-based (built-in)    | Token-based (built-in)     |
# | Metadata store           | BoltDB                    | Embedded catalog           |
# | Telemetry env prefix     | INFLUXD_                  | INFLUXDB3_                 |
