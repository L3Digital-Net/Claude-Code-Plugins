# Annotated cassandra.yaml
# Each directive includes: what it does, default value, recommended value,
# and when to change it. Directive order follows the standard cassandra.yaml layout.
#
# After editing cassandra.yaml, restart the Cassandra service:
#   sudo systemctl restart cassandra
# Most settings cannot be changed at runtime. Exceptions are noted.
#
# Config path: /etc/cassandra/cassandra.yaml
# JVM tuning: /etc/cassandra/cassandra-env.sh (heap, GC settings)
# DC/Rack assignment: /etc/cassandra/cassandra-rackdc.properties

# ---------------------------------------------------------------------------
# CLUSTER IDENTITY
# ---------------------------------------------------------------------------

# Logical cluster name. Nodes with different cluster names refuse to join
# each other, preventing accidental cross-cluster contamination.
# Default: 'Test Cluster'  |  Recommended: a descriptive name for your deployment
# Change when: initial setup. Cannot be changed after data is written without
#   wiping all node data. Use something meaningful (e.g., "prod-us-east").
cluster_name: 'Test Cluster'

# Number of virtual tokens assigned to this node on the consistent hash ring.
# More tokens = more even data distribution across heterogeneous hardware.
# Default: 256  |  Recommended: 16 for new clusters (Cassandra 4.0+ guidance)
#   Lower values reduce streaming time during topology changes and repair.
# Change when: initial cluster setup. Changing on an existing node requires
#   decommission and re-bootstrap.
num_tokens: 256

# Optimize token allocation for a specific keyspace's replication strategy.
# Only works with Murmur3Partitioner.
# Default: not set  |  Recommended: set to your primary keyspace name
# Change when: you want better token distribution for a specific replication
#   factor. Mutually exclusive with manually assigned initial_token.
# allocate_tokens_for_keyspace: my_keyspace

# ---------------------------------------------------------------------------
# SEED PROVIDER
# ---------------------------------------------------------------------------

# Seeds are the initial contact points for a new node joining the cluster.
# The default SimpleSeedProvider takes a static comma-separated list of IPs.
# 2-3 seeds per datacenter is sufficient; not every node needs to be a seed.
# A node should NOT list itself as its only seed.
# Default: 127.0.0.1  |  Recommended: 2-3 stable node IPs per DC
# Change when: initial setup or when seed nodes are replaced.
seed_provider:
  - class_name: org.apache.cassandra.locator.SimpleSeedProvider
    parameters:
      - seeds: "127.0.0.1"

# ---------------------------------------------------------------------------
# NETWORK ADDRESSES
# ---------------------------------------------------------------------------

# Address this node listens on for inter-node communication (gossip, streaming).
# Must be reachable by all other cluster nodes.
# Default: localhost  |  Recommended: the node's private IP address
# Change when: initial setup. Set to the IP on the network shared with other
#   Cassandra nodes. Use listen_interface as an alternative (set one, not both).
listen_address: localhost

# Alternative to listen_address: bind to a named network interface.
# Default: not set  |  Recommended: use listen_address instead for clarity
# Cannot be set simultaneously with listen_address.
# listen_interface: eth0

# Address advertised to other nodes for inter-node communication.
# Default: same as listen_address  |  Recommended: leave unset unless behind NAT
# Change when: the node's listen_address is not directly routable (e.g., in
#   EC2 with public/private addressing, or behind NAT).
# broadcast_address: 1.2.3.4

# Address this node listens on for CQL client connections.
# Default: localhost  |  Recommended: the node's private IP, or 0.0.0.0 to
#   accept connections on all interfaces.
# Change when: client applications connect from other hosts.
rpc_address: localhost

# Address advertised to CQL drivers for client connections.
# Default: same as rpc_address  |  Recommended: set explicitly when rpc_address
#   is 0.0.0.0 (required in that case).
# Change when: clients connect via a different IP than the local bind address.
# broadcast_rpc_address: 1.2.3.4

# ---------------------------------------------------------------------------
# NETWORK PORTS
# ---------------------------------------------------------------------------

# CQL native transport port for client connections.
# Default: 9042  |  Recommended: 9042
# Change when: port conflicts exist on the host.
native_transport_port: 9042

# Dedicated SSL port for CQL native transport. Allows running encrypted and
# unencrypted native transport on different ports simultaneously.
# Default: 9142  |  Recommended: use client_encryption_options instead of a
#   separate port for modern deployments.
# native_transport_port_ssl: 9142

# Inter-node communication port (gossip protocol, streaming, repair).
# Default: 7000  |  Recommended: 7000
# Change when: port conflicts on the host. Must be open between all cluster nodes.
storage_port: 7000

# SSL inter-node communication port.
# Default: 7001  |  Recommended: 7001 (only used when internode_encryption is
#   enabled in server_encryption_options).
ssl_storage_port: 7001

# ---------------------------------------------------------------------------
# DATA DIRECTORIES
# ---------------------------------------------------------------------------

# Directories for SSTable data files. Multiple directories spread I/O
# across disks (Cassandra round-robins new SSTables across them).
# Default: $CASSANDRA_HOME/data/data  |  Recommended: dedicated volume(s)
# Change when: initial setup. Place on fast storage with ample capacity.
#   Production deployments should use separate volumes from commitlog.
data_file_directories:
  - /var/lib/cassandra/data

# Commit log directory. Write-ahead log for durability. Must be on fast
# storage; ideally a separate physical disk from data_file_directories
# to avoid I/O contention.
# Default: $CASSANDRA_HOME/data/commitlog  |  Recommended: dedicated volume
# Change when: initial setup or when commitlog disk fills up.
commitlog_directory: /var/lib/cassandra/commitlog

# Directory for serialized row caches and key caches on shutdown.
# Caches are reloaded on startup to warm the node faster.
# Default: $CASSANDRA_HOME/data/saved_caches  |  Recommended: /var/lib/cassandra/saved_caches
saved_caches_directory: /var/lib/cassandra/saved_caches

# Directory for hinted handoff data. Hints are stored when a target node is
# temporarily down, then replayed when it comes back.
# Default: $CASSANDRA_HOME/data/hints  |  Recommended: /var/lib/cassandra/hints
# hints_directory: /var/lib/cassandra/hints

# ---------------------------------------------------------------------------
# PARTITIONER
# ---------------------------------------------------------------------------

# Determines how partition keys are mapped to the token ring. The partitioner
# CANNOT be changed after data has been written without a full cluster rebuild.
# Default: org.apache.cassandra.dht.Murmur3Partitioner
# Recommended: Murmur3Partitioner (uniform distribution, good performance)
# Other values: RandomPartitioner (legacy), ByteOrderedPartitioner (range scans
#   but causes hotspots; avoid unless you have a specific reason).
partitioner: org.apache.cassandra.dht.Murmur3Partitioner

# ---------------------------------------------------------------------------
# SNITCH (TOPOLOGY)
# ---------------------------------------------------------------------------

# Teaches Cassandra about your network topology for replica placement.
# The snitch CANNOT be changed to an incompatible type after data is inserted.
# Default: SimpleSnitch  |  Recommended: GossipingPropertyFileSnitch for
#   multi-DC production (reads DC/rack from cassandra-rackdc.properties).
# Accepted: SimpleSnitch, GossipingPropertyFileSnitch, PropertyFileSnitch,
#   Ec2Snitch, Ec2MultiRegionSnitch, GoogleCloudSnitch, RackInferringSnitch
# Change when: deploying across datacenters or racks, or in cloud environments.
endpoint_snitch: SimpleSnitch

# ---------------------------------------------------------------------------
# COMMIT LOG
# ---------------------------------------------------------------------------

# How the commit log is synced to disk.
#   periodic: acks writes immediately; syncs every commitlog_sync_period_in_ms.
#     Risk: up to one sync period of data loss on crash.
#   batch: waits for fsync before acknowledging. Safest; higher write latency.
# Default: batch  |  Recommended: periodic (standard for most workloads)
# Change when: you need guaranteed durability per write (use batch) or
#   maximum write throughput (use periodic with acceptable data loss window).
commitlog_sync: periodic

# Interval between periodic commit log fsyncs (only with commitlog_sync: periodic).
# Default: 10000 (10 seconds)  |  Recommended: 10000
# Change when: you want a tighter data loss window (lower value, higher disk I/O)
#   or less disk overhead (higher value, more data at risk).
commitlog_sync_period_in_ms: 10000

# Maximum size of individual commit log segments before rotation.
# Default: 32 (MB)  |  Recommended: 32
# Change when: large mutations cause frequent segment rotation (raise to 64).
#   Must be less than 2048. Larger segments take longer to replay on crash recovery.
commitlog_segment_size_in_mb: 32

# ---------------------------------------------------------------------------
# MEMTABLE
# ---------------------------------------------------------------------------

# Memory allocation strategy for memtables (in-memory write buffer before flush).
# Default: heap_buffers  |  Recommended: heap_buffers for most deployments
# Accepted: heap_buffers, offheap_buffers, offheap_objects
# Change when: GC pressure from memtables is problematic — offheap_buffers
#   moves memtable data off the Java heap, reducing GC pause times.
memtable_allocation_type: heap_buffers

# Total heap memory for memtables before Cassandra starts flushing.
# Default: 1/4 of MAX_HEAP_SIZE if not set  |  Recommended: leave unset
#   (let Cassandra auto-calculate based on heap).
# Change when: you need explicit control over memtable memory vs. other heap users.
# memtable_heap_space_in_mb: 2048

# Total off-heap memory for memtables (when using offheap_buffers or offheap_objects).
# Default: 1/4 of MAX_HEAP_SIZE if not set  |  Recommended: leave unset
# memtable_offheap_space_in_mb: 2048

# ---------------------------------------------------------------------------
# COMPACTION
# ---------------------------------------------------------------------------

# Maximum throughput for compaction across all compaction threads (MB/sec).
# Throttles compaction I/O to prevent it from starving client reads/writes.
# Default: 16  |  Recommended: 64 for SSD-backed nodes; 16 for HDD
# Change when: compaction pending count grows (raise) or compaction I/O
#   causes latency spikes for client operations (lower). 0 disables throttling.
# Runtime-adjustable via nodetool: nodetool setcompactionthroughput <MB/s>
compaction_throughput_mb_per_sec: 16

# Number of concurrent compaction threads.
# Default: min(number_of_disks, number_of_cores), max 8
# Recommended: leave unset (auto-calculated) for most deployments
# Change when: you have many cores and fast disks and want more parallelism.
# concurrent_compactors: 2

# ---------------------------------------------------------------------------
# THREAD POOLS (CONCURRENCY)
# ---------------------------------------------------------------------------

# Maximum concurrent read requests served by this node.
# Default: 32  |  Recommended: 16 * number_of_drives (e.g., 32 for 2 drives)
# Change when: read latency is high and CPU/disk are underutilized (raise),
#   or CPU is saturated from too many parallel reads (lower).
concurrent_reads: 32

# Maximum concurrent write requests served by this node.
# Default: 32  |  Recommended: 8 * number_of_cores
# Change when: write throughput is limited by thread availability. Writes
#   are less disk-bound than reads because they go to the commit log + memtable.
concurrent_writes: 32

# Maximum concurrent counter write requests. Counter writes require a
# read-before-write, so they are heavier than regular writes.
# Default: 32  |  Recommended: 32
# Change when: counter-heavy workloads need more parallelism.
concurrent_counter_writes: 32

# ---------------------------------------------------------------------------
# TIMEOUTS
# ---------------------------------------------------------------------------

# How long the coordinator waits for read replicas to respond (ms).
# Default: 5000  |  Recommended: 5000
# Change when: reads frequently time out due to large partitions or slow disks.
#   Raising the timeout masks the real problem; fix the data model or hardware.
read_request_timeout_in_ms: 5000

# How long the coordinator waits for write acknowledgments from replicas (ms).
# Default: 2000  |  Recommended: 2000
# Change when: writes time out under heavy load. Same caveat as read timeouts.
write_request_timeout_in_ms: 2000

# ---------------------------------------------------------------------------
# AUTHENTICATION AND AUTHORIZATION
# ---------------------------------------------------------------------------

# Authentication backend. Controls whether clients must provide credentials.
# Default: AllowAllAuthenticator (no auth)
# Recommended: PasswordAuthenticator for production
# Change when: deploying to production. After enabling, the default superuser
#   is cassandra/cassandra — change this password immediately, then create
#   dedicated application users.
authenticator: AllowAllAuthenticator

# Authorization backend. Controls whether authenticated users have per-resource
# permissions enforced.
# Default: AllowAllAuthorizer (no authorization checks)
# Recommended: CassandraAuthorizer for production (GRANT/REVOKE permissions)
# Change when: you enable PasswordAuthenticator — auth without authorization
#   means every authenticated user has full access to everything.
authorizer: AllowAllAuthorizer

# Role management backend. Manages role hierarchy (role inheritance, membership).
# Default: CassandraRoleManager  |  Recommended: CassandraRoleManager
# Change when: integrating with an external role store (custom implementation).
# role_manager: CassandraRoleManager

# ---------------------------------------------------------------------------
# INTERNODE ENCRYPTION (server_encryption_options)
# ---------------------------------------------------------------------------

# Encryption for traffic between Cassandra nodes (gossip, streaming, repair).
server_encryption_options:
    # Which inter-node connections to encrypt.
    # Default: none  |  Recommended: all for production
    # Accepted: none, all, dc (cross-DC only), rack (cross-rack only)
    # Change when: securing a production cluster. Start with dc to encrypt
    #   only cross-datacenter traffic if same-DC links are on a trusted network.
    internode_encryption: none

    # Java keystore containing this node's private key and certificate.
    # Default: conf/.keystore  |  Recommended: a dedicated keystore per node
    # Change when: setting up internode encryption.
    keystore: conf/.keystore
    keystore_password: cassandra

    # Java truststore containing CA certificates for verifying peer nodes.
    # Default: conf/.truststore  |  Recommended: a shared truststore with your CA cert
    truststore: conf/.truststore
    truststore_password: cassandra

    # Require client (peer node) certificates during the TLS handshake.
    # Default: false  |  Recommended: true for mutual TLS in production
    # require_client_auth: false

    # Key manager algorithm and TLS protocol version.
    # Default: SunX509 / TLS  |  Recommended: keep defaults
    # algorithm: SunX509
    # protocol: TLS

    # Restrict cipher suites. Empty list uses JVM defaults.
    # Change when: compliance requirements mandate specific ciphers.
    # cipher_suites: [TLS_RSA_WITH_AES_128_CBC_SHA]

# ---------------------------------------------------------------------------
# CLIENT ENCRYPTION (client_encryption_options)
# ---------------------------------------------------------------------------

# Encryption for CQL native transport connections from client applications.
client_encryption_options:
    # Enable TLS for client connections.
    # Default: false  |  Recommended: true for production
    # Change when: deploying to production or when clients connect over
    #   untrusted networks.
    enabled: false

    # Allow both encrypted and unencrypted client connections simultaneously.
    # Default: false  |  Recommended: false (enforce encryption for all clients)
    # Change when: migrating clients to TLS incrementally — enable optional
    #   temporarily, then disable once all clients support TLS.
    optional: false

    # Keystore containing the server certificate presented to clients.
    # Default: conf/.keystore  |  Recommended: a dedicated keystore
    keystore: conf/.keystore
    keystore_password: cassandra

    # Require client certificates (mutual TLS).
    # Default: false  |  Recommended: true for zero-trust environments
    # Change when: you want to authenticate clients via certificate in
    #   addition to (or instead of) username/password.
    # require_client_auth: false

    # Truststore for verifying client certificates (only needed with
    # require_client_auth: true).
    # truststore: conf/.truststore
    # truststore_password: cassandra
