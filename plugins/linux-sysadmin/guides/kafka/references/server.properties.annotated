# server.properties — Annotated Apache Kafka KRaft Configuration
#
# Location: /opt/kafka/config/server.properties (combined mode)
#            /opt/kafka/config/kraft/controller.properties (controller-only)
#            /opt/kafka/config/kraft/broker.properties (broker-only)
# Apply changes: rolling restart of each broker/controller (no live reload)
# Format storage before first start:
#   KAFKA_CLUSTER_ID="$(kafka-storage.sh random-uuid)"
#   kafka-storage.sh format --standalone -t $KAFKA_CLUSTER_ID -c server.properties
#
# Kafka 4.0+ is KRaft-only; ZooKeeper support has been removed. This file
# documents the KRaft configuration model. Java .properties format uses #
# for comments natively.

# =============================================================================
# KRAFT IDENTITY
# =============================================================================

# process.roles: Role(s) this Kafka process fulfills.
# Default: not set (required — process will not start without it)
# Options:
#   broker             — handles client produce/consume traffic
#   controller         — manages cluster metadata via Raft consensus
#   broker,controller  — combined mode (development/single-node only)
# Production clusters should separate controller and broker roles so each can
# be scaled, upgraded, and resource-tuned independently.
process.roles=broker,controller

# node.id: Unique integer identifier for this node across all brokers and
# controllers in the cluster.
# Default: not set (required)
# Must be unique within the cluster. By convention, start from 1.
# Replaces the old broker.id from ZooKeeper mode.
node.id=1

# controller.quorum.voters: Static list of all controller nodes in the cluster.
# Format: {node.id}@{host}:{controller-port}
# Default: "" (empty — required for static quorum configuration)
# Every node in the cluster (brokers and controllers) must list all controllers
# here. The node IDs must match each controller's node.id setting.
# NOTE: Deprecated in KRaft version 1 in favor of
# controller.quorum.bootstrap.servers. After upgrading KRaft metadata version,
# migrate to bootstrap.servers and remove this property.
controller.quorum.voters=1@localhost:9093

# controller.quorum.bootstrap.servers: Dynamic controller discovery endpoints.
# Format: {host}:{controller-port} (comma-separated)
# Default: not set
# Replacement for controller.quorum.voters in KRaft version 1+. Supports
# dynamic controller membership changes without listing node IDs.
# controller.quorum.bootstrap.servers=controller1:9093,controller2:9093,controller3:9093

# =============================================================================
# LISTENERS
# =============================================================================

# listeners: Comma-separated list of URIs this process listens on.
# Format: {listener_name}://{host}:{port}
# Default: PLAINTEXT://:9092
# Each listener name is mapped to a security protocol via
# listener.security.protocol.map. Controllers must include their controller
# listener; brokers must include their client and inter-broker listeners.
listeners=PLAINTEXT://:9092,CONTROLLER://:9093

# advertised.listeners: Addresses advertised to clients for establishing
# connections. Clients use these to connect, so they must be routable from
# the client's network.
# Default: null (uses the value from listeners)
# Set when: the broker is behind a NAT, load balancer, or runs in a container
# with port mapping. Controller listeners must NOT appear here.
advertised.listeners=PLAINTEXT://localhost:9092

# inter.broker.listener.name: Listener name used for broker-to-broker
# replication traffic.
# Default: null (required on KRaft brokers)
# Must be a listener defined in listeners and NOT a controller listener.
# In combined mode, typically set to the client listener name.
inter.broker.listener.name=PLAINTEXT

# controller.listener.names: Comma-separated listener names for the controller
# quorum. Must appear in listeners but NOT in advertised.listeners.
# Default: null (required on KRaft controllers)
controller.listener.names=CONTROLLER

# listener.security.protocol.map: Maps listener names to security protocols.
# Default: all standard names map to themselves
#   (PLAINTEXT->PLAINTEXT, SSL->SSL, SASL_PLAINTEXT->SASL_PLAINTEXT, SASL_SSL->SASL_SSL)
# Custom listener names (like CONTROLLER) must be mapped here.
listener.security.protocol.map=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,SSL:SSL,SASL_PLAINTEXT:SASL_PLAINTEXT,SASL_SSL:SASL_SSL

# =============================================================================
# STORAGE
# =============================================================================

# log.dirs: Comma-separated list of directories where Kafka stores partition
# log data. Kafka stripes partitions across all listed directories.
# Default: null (required — must be set explicitly)
# Use multiple directories on separate physical disks for better I/O
# throughput. Despite the name "log", this is where all message data lives.
# NOTE: log.dirs (plural) takes precedence over log.dir (singular). Mixing
# them causes data to land in unexpected directories.
log.dirs=/opt/kafka/data

# metadata.log.dir: Directory for the KRaft metadata log (__cluster_metadata
# topic). Separating metadata from data improves controller performance.
# Default: null (uses first directory in log.dirs)
# On dedicated controller nodes, point this to a fast, low-latency disk.
# metadata.log.dir=/opt/kafka/metadata

# =============================================================================
# TOPIC DEFAULTS
# =============================================================================

# num.partitions: Default partition count for automatically created topics.
# Default: 1
# A single partition limits consumer parallelism to one instance per consumer
# group. Set to at least 3 for production. This only affects auto-created
# topics; explicitly created topics specify their own partition count.
# Cannot be decreased after topic creation.
num.partitions=1

# default.replication.factor: Default replication factor for automatically
# created topics and topics created with replication factor -1.
# Default: 1
# Set to 3 for production clusters with 3+ brokers. A replication factor of 1
# means a single broker failure loses that partition's data.
default.replication.factor=1

# auto.create.topics.enable: Automatically create a topic when a producer or
# consumer references a non-existent topic name.
# Default: true
# Disable in production. A typo in a topic name silently creates a garbage
# topic that consumes resources and clutters the topic list. Create topics
# explicitly with kafka-topics.sh.
auto.create.topics.enable=true

# min.insync.replicas: Minimum number of replicas (including the leader) that
# must acknowledge a write for it to be considered successful. Only enforced
# when the producer sets acks=all (or acks=-1).
# Default: 1
# With default of 1, acks=all provides no durability benefit over acks=1.
# Set to 2 with replication.factor=3 for production data safety: the cluster
# tolerates one broker failure without data loss or write unavailability.
min.insync.replicas=1

# message.max.bytes: Maximum size of a single record batch (after compression,
# including overhead).
# Default: 1048588 (~1 MiB)
# If producers send large messages, increase this along with the producer's
# max.request.size and the consumer's max.partition.fetch.bytes. Also check
# the topic-level max.message.bytes override.
message.max.bytes=1048588

# compression.type: Default compression for topic data.
# Default: producer (broker stores data in whatever compression the producer
# used)
# Options: uncompressed, zstd, lz4, snappy, gzip, producer
# Setting a specific type forces re-compression on the broker, which adds CPU
# overhead but normalizes storage format. "producer" is usually best.
compression.type=producer

# =============================================================================
# LOG RETENTION
# =============================================================================

# log.retention.hours: Time-based retention. Messages older than this are
# eligible for deletion. Also settable as log.retention.minutes or
# log.retention.ms (most granular wins).
# Default: 168 (7 days)
# Adjust based on your replay/reprocessing needs. High-throughput topics may
# need shorter retention to control disk usage.
log.retention.hours=168

# log.retention.bytes: Size-based retention per partition. When a partition's
# log exceeds this size, the oldest segments are deleted.
# Default: -1 (unlimited — no size-based deletion)
# Set this alongside time-based retention for high-throughput topics to prevent
# disk exhaustion. Value is per-partition, not per-topic.
log.retention.bytes=-1

# log.segment.bytes: Maximum size of a single log segment file. When a segment
# reaches this size, a new segment is created. Segments are the unit of
# retention deletion and compaction.
# Default: 1073741824 (1 GiB)
# Smaller segments mean finer-grained retention but more file handles. Larger
# segments reduce file handle count but increase the granularity of deletion.
log.segment.bytes=1073741824

# log.cleanup.policy: How old data is handled.
# Default: delete
# Options:
#   delete  — remove segments exceeding retention time or size
#   compact — keep only the latest value per key (for changelog/state topics)
#   delete,compact — both policies active
# Compact is essential for topics used as key-value stores (e.g., Kafka
# Streams state stores, Connect offset storage).
log.cleanup.policy=delete

# log.retention.check.interval.ms: How often the log cleaner checks for
# segments eligible for deletion.
# Default: 300000 (5 minutes)
# Reducing this makes retention enforcement more responsive but adds minor CPU
# overhead from more frequent scans.
log.retention.check.interval.ms=300000

# =============================================================================
# INTERNAL TOPIC REPLICATION
# =============================================================================

# offsets.topic.replication.factor: Replication factor for the __consumer_offsets
# internal topic, which stores committed consumer group offsets.
# Default: 3
# Must not exceed the number of brokers. In development with a single broker,
# set to 1. In production, keep at 3.
offsets.topic.replication.factor=3

# transaction.state.log.replication.factor: Replication factor for the
# __transaction_state internal topic, used by exactly-once transactional
# producers.
# Default: 3
# Same sizing rules as offsets.topic.replication.factor.
transaction.state.log.replication.factor=3

# transaction.state.log.min.isr: Minimum in-sync replicas for the transaction
# state topic. Writes to the transaction coordinator fail if fewer replicas are
# in sync.
# Default: 2
# With replication factor 3 and min ISR 2, the cluster tolerates one broker
# failure for transactional writes. In single-broker dev, set to 1.
transaction.state.log.min.isr=2

# =============================================================================
# CONSUMER GROUP COORDINATION
# =============================================================================

# group.initial.rebalance.delay.ms: Time the group coordinator waits after the
# first consumer joins a new group before triggering the first rebalance.
# Default: 3000 (3 seconds)
# Gives additional consumers time to join before the initial assignment,
# avoiding unnecessary rebalances during application startup. Set to 0 in
# development for immediate rebalancing.
group.initial.rebalance.delay.ms=3000

# =============================================================================
# NETWORK THREADS
# =============================================================================

# num.network.threads: Threads handling network I/O (reading requests from the
# socket and writing responses back).
# Default: 3
# Increase on brokers with many client connections or high request rates.
# These threads are CPU-light (just socket I/O); the heavy lifting happens in
# I/O threads.
num.network.threads=3

# num.io.threads: Threads processing requests, including disk I/O for reads
# and writes.
# Default: 8
# Should be at least the number of disks used for log.dirs. Increase for
# high-throughput brokers with many partitions.
num.io.threads=8

# num.recovery.threads.per.data.dir: Threads per data directory used for log
# recovery at startup (replaying uncommitted writes) and flushing at shutdown.
# Default: 1
# Increase to speed up broker startup after an unclean shutdown, especially
# when log.dirs contains many partitions. A value of 2-4 per directory is
# common in production.
num.recovery.threads.per.data.dir=1

# =============================================================================
# SOCKET SETTINGS
# =============================================================================

# socket.send.buffer.bytes: SO_SNDBUF size for broker sockets.
# Default: 102400 (100 KiB)
# For cross-datacenter replication or high-latency networks, increase to
# match the bandwidth-delay product (e.g., 1 MiB for 100 Mbps * 80ms RTT).
# Set to -1 to use the OS default.
socket.send.buffer.bytes=102400

# socket.receive.buffer.bytes: SO_RCVBUF size for broker sockets.
# Default: 102400 (100 KiB)
# Same tuning guidance as socket.send.buffer.bytes.
socket.receive.buffer.bytes=102400

# socket.request.max.bytes: Maximum size of a request the broker will accept.
# Default: 104857600 (100 MiB)
# Protects against OOM from malformed or malicious requests. Must be larger
# than message.max.bytes plus request overhead.
socket.request.max.bytes=104857600

# =============================================================================
# SECURITY PROTOCOL SETTINGS
# =============================================================================

# To enable TLS (SSL) for client connections:
#
# 1. Generate a keystore and truststore using keytool (see Kafka security docs)
#
# 2. Configure the broker (replace paths and use strong secrets):
#    ssl.keystore.location=/opt/kafka/config/server.keystore.jks
#    ssl.keystore.password=<YOUR_KEYSTORE_SECRET>
#    ssl.key.password=<YOUR_KEY_SECRET>
#    ssl.truststore.location=/opt/kafka/config/server.truststore.jks
#    ssl.truststore.password=<YOUR_TRUSTSTORE_SECRET>
#
# 3. Update listener.security.protocol.map to use SSL or SASL_SSL:
#    listener.security.protocol.map=BROKER:SSL,CONTROLLER:SSL
#
# 4. For SASL authentication (SCRAM, OAUTHBEARER, GSSAPI):
#    sasl.enabled.mechanisms=SCRAM-SHA-512
#    sasl.mechanism.inter.broker.protocol=SCRAM-SHA-512
#    listener.name.broker.scram-sha-512.sasl.jaas.config=...

# ssl.client.auth: Whether clients must present a certificate for mTLS.
# Default: none
# Options: none, requested (optional), required (mandatory)
# ssl.client.auth=required

# ssl.endpoint.identification.algorithm: Hostname verification for SSL.
# Default: https (verify hostname matches certificate SAN/CN)
# Set to empty string to disable hostname verification (not recommended).
# ssl.endpoint.identification.algorithm=https

## Deployment Notes

# Format storage (required before first startup):
#   KAFKA_CLUSTER_ID="$(kafka-storage.sh random-uuid)"
#   kafka-storage.sh format --standalone -t $KAFKA_CLUSTER_ID -c /opt/kafka/config/server.properties

# Start the broker:
#   kafka-server-start.sh /opt/kafka/config/server.properties
#   # Or via systemd if you created a unit file

# Verify the broker is running:
#   kafka-topics.sh --list --bootstrap-server localhost:9092

# Production checklist:
# 1. Separate controller and broker roles (process.roles=broker or controller)
# 2. Set default.replication.factor=3, min.insync.replicas=2
# 3. Disable auto.create.topics.enable
# 4. Set num.partitions to at least 3
# 5. Configure TLS + SASL on all listeners
# 6. Set JMX_PORT in environment for monitoring
# 7. Tune JVM heap: KAFKA_HEAP_OPTS="-Xms6g -Xmx6g" (6 GiB typical for
#    brokers; remaining RAM for page cache)
# 8. Use XFS filesystem for log.dirs with noatime mount option
# 9. Set vm.swappiness=1 and increase vm.dirty_ratio for write-heavy workloads
