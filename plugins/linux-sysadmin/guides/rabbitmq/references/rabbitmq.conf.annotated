# rabbitmq.conf — Annotated RabbitMQ Configuration (sysctl / new-style format)
#
# Location: /etc/rabbitmq/rabbitmq.conf
# Apply changes: systemctl restart rabbitmq-server  (most settings require a full restart)
# Validate: rabbitmq-diagnostics check_running  (after restart)
#
# This is the "new-style" sysctl format introduced in RabbitMQ 3.7. The old
# Erlang term format (rabbitmq.config) is deprecated; use advanced.config only
# for settings that cannot be expressed in sysctl format.
#
# Drop-in overrides: place additional .conf files in /etc/rabbitmq/conf.d/
# (loaded alphabetically; later files override earlier ones).

# =============================================================================
# LISTENERS — TCP (AMQP 0-9-1 / AMQP 1.0)
# =============================================================================

# listeners.tcp.default: Port for unencrypted AMQP client connections.
# Default: 5672
# Set to 'none' to disable all TCP listeners (TLS-only mode).
listeners.tcp.default = 5672

# To bind to a specific interface instead of all interfaces:
# listeners.tcp.local    = 127.0.0.1:5672
# listeners.tcp.local_v6 = ::1:5672

# num_acceptors.tcp: Number of Erlang processes accepting new TCP connections.
# Default: 10
# Increase for high-connection-rate workloads (hundreds of connects/sec).
num_acceptors.tcp = 10

# =============================================================================
# LISTENERS — TLS (AMQPS)
# =============================================================================

# listeners.ssl.default: Port for TLS-encrypted AMQP connections.
# Default: not set (TLS disabled)
# Enable by uncommenting and configuring the ssl_options below.
# listeners.ssl.default = 5671

# num_acceptors.ssl: Number of Erlang processes accepting TLS connections.
# Default: 10
# num_acceptors.ssl = 10

# =============================================================================
# TLS OPTIONS
# =============================================================================

# These apply to the AMQP TLS listener (port 5671). Management TLS has its own
# settings under management.ssl.* below.

# ssl_options.cacertfile: CA certificate bundle for verifying client certs.
# Default: none
# ssl_options.cacertfile = /etc/rabbitmq/tls/ca_certificate.pem

# ssl_options.certfile: Server certificate presented to connecting clients.
# Default: none
# ssl_options.certfile = /etc/rabbitmq/tls/server_certificate.pem

# ssl_options.keyfile: Private key for the server certificate.
# Default: none
# ssl_options.keyfile = /etc/rabbitmq/tls/server_key.pem

# ssl_options.verify: Peer certificate verification mode.
# Default: verify_none
# Options: verify_peer (require client certs), verify_none (don't verify)
# Set to verify_peer for mutual TLS between clients and the broker.
# ssl_options.verify = verify_peer

# ssl_options.fail_if_no_peer_cert: Reject connections where the client does
# not present a certificate. Only meaningful when verify = verify_peer.
# Default: false
# ssl_options.fail_if_no_peer_cert = true

# ssl_options.versions: Restrict allowed TLS protocol versions.
# Default: system OpenSSL defaults (typically TLSv1.2 and TLSv1.3)
# ssl_options.versions.1 = tlsv1.3
# ssl_options.versions.2 = tlsv1.2

# ssl_options.honor_cipher_order: Enforce the server's cipher preference order
# rather than the client's.
# Default: false
# Set to true to ensure the strongest mutually supported cipher is selected.
# ssl_options.honor_cipher_order = true

# ssl_options.honor_ecc_order: Enforce the server's elliptic curve preference.
# Default: false
# ssl_options.honor_ecc_order = true

# ssl_handshake_timeout: Maximum time for a TLS handshake to complete (ms).
# Default: 5000
# Increase on high-latency networks or when using hardware security modules.
ssl_handshake_timeout = 5000

# =============================================================================
# MANAGEMENT PLUGIN
# =============================================================================

# management.tcp.port: HTTP port for the management UI and API.
# Default: 15672
# Requires: rabbitmq_management plugin enabled
# Restrict access via firewall rules or a reverse proxy; the management API
# exposes full broker control.
management.tcp.port = 15672

# management.tcp.ip: Interface to bind the management listener to.
# Default: 0.0.0.0 (all interfaces)
# Set to 127.0.0.1 to restrict to localhost, then front with a reverse proxy.
# management.tcp.ip = 0.0.0.0

# management.ssl.port: HTTPS port for the management UI.
# Default: 15671
# Requires its own TLS certificate configuration (separate from AMQP TLS).
# management.ssl.port      = 15671
# management.ssl.cacertfile = /etc/rabbitmq/tls/ca_certificate.pem
# management.ssl.certfile   = /etc/rabbitmq/tls/server_certificate.pem
# management.ssl.keyfile    = /etc/rabbitmq/tls/server_key.pem

# =============================================================================
# DEFAULT USER AND AUTHENTICATION
# =============================================================================

# default_user / default_pass: Credentials created when RabbitMQ initializes a
# fresh database. These only apply on first startup with an empty Mnesia
# database.
# Default: guest / guest
# CHANGE IMMEDIATELY after installation. The guest account is restricted to
# localhost connections by default (see loopback_users below), but relying on a
# well-known password is a security risk. Create a new admin user with
# rabbitmqctl and delete or lock the guest account.
default_user = guest
default_pass = guest

# loopback_users.guest: Restrict the guest user to loopback (localhost)
# connections only.
# Default: true (guest can only connect from 127.0.0.1 / ::1)
# Set to false (loopback_users = none) to allow guest from any host.
# WARNING: never disable in production; create proper users instead.
loopback_users.guest = true

# default_user_tags: Tags assigned to the default user on database creation.
# Default: administrator = true
# Tags control management UI access levels: administrator, monitoring,
# policymaker, management, or none.
default_user_tags.administrator = true

# =============================================================================
# MEMORY AND DISK RESOURCE LIMITS
# =============================================================================

# vm_memory_high_watermark: Memory threshold that triggers flow control,
# blocking all publishers until memory drops below the threshold. Can be
# relative (fraction of total RAM) or absolute.
# Default: 0.6 (60% of detected system memory)
# On dedicated broker hosts, 0.6-0.7 is typical. In containers, verify that
# RabbitMQ detects the correct cgroup memory limit, or use
# total_memory_available_override_value to set it explicitly.
vm_memory_high_watermark.relative = 0.6

# Alternative absolute form (bytes or unit suffix):
# vm_memory_high_watermark.absolute = 2GB

# vm_memory_calculation_strategy: How RabbitMQ measures its own memory usage.
# Default: rss
# Options: rss (resident set size, recommended), allocated (Erlang allocator
# stats), legacy (older Erlang method)
# "rss" matches what the OS reports and is the most intuitive.
vm_memory_calculation_strategy = rss

# total_memory_available_override_value: Override auto-detected total system
# memory. Useful in containers where the OS reports the host's RAM instead of
# the cgroup limit.
# Default: not set (auto-detected)
# total_memory_available_override_value = 4GB

# disk_free_limit: Minimum free disk space on the partition holding
# /var/lib/rabbitmq. When free space drops below this, all publishers are
# blocked. Can be absolute or relative (multiplier of total RAM).
# Default: 50MB (absolute)
# 50MB is dangerously low for production. Use a relative limit of 1.0-2.0
# (1x-2x RAM) so the broker stops accepting messages before the OS runs out
# of space for paging or Mnesia operations.
disk_free_limit.absolute = 50MB

# Alternative relative form (multiplier of total RAM):
# disk_free_limit.relative = 2.0

# =============================================================================
# CLUSTER FORMATION AND PEER DISCOVERY
# =============================================================================

# cluster_formation.peer_discovery_backend: Mechanism for discovering cluster
# peers on first boot.
# Default: rabbit_peer_discovery_classic_config (static node list)
# Options:
#   rabbit_peer_discovery_classic_config — static list in this file
#   rabbit_peer_discovery_dns            — DNS A/SRV record lookup
#   rabbit_peer_discovery_consul         — HashiCorp Consul
#   rabbit_peer_discovery_etcd           — etcd
#   rabbit_peer_discovery_k8s            — Kubernetes API
cluster_formation.peer_discovery_backend = rabbit_peer_discovery_classic_config

# cluster_formation.classic_config.nodes: Static list of cluster peers.
# Only used with the classic_config backend.
# cluster_formation.classic_config.nodes.1 = rabbit@rabbit1.internal
# cluster_formation.classic_config.nodes.2 = rabbit@rabbit2.internal
# cluster_formation.classic_config.nodes.3 = rabbit@rabbit3.internal

# cluster_formation.dns.hostname: DNS hostname returning A records for cluster
# peers. Only used with the dns discovery backend.
# cluster_formation.dns.hostname = rabbitmq.service.consul

# cluster_formation.node_type: Whether this node stores data on disk or RAM.
# Default: disc
# Options: disc (persistent storage, recommended), ram (data in memory only,
# useful for temporary/transient nodes in specific architectures)
# RAM nodes cannot host quorum queues. Use disc for all production nodes.
cluster_formation.node_type = disc

# cluster_partition_handling: Strategy when a network partition splits the
# cluster into isolated groups.
# Default: ignore (no automatic action; risks split-brain)
# Options:
#   ignore         — do nothing (manual resolution required)
#   autoheal       — restart nodes on the losing side automatically
#   pause_minority — pause nodes in the minority partition (safest for >= 3 nodes)
#   pause_if_all_down — pause if specified nodes are unreachable
# Production clusters should use pause_minority (when nodes span racks/AZs) or
# autoheal (when availability matters more than consistency).
cluster_partition_handling = pause_minority

# cluster_keepalive_interval: Milliseconds between keepalive messages sent to
# other cluster nodes.
# Default: 10000 (10 seconds)
cluster_keepalive_interval = 10000

# cluster_name: Human-readable cluster identifier. Shown in the management UI
# and used by federation to distinguish clusters.
# Default: derived from the first node's name
# cluster_name = rabbitmq-prod

# =============================================================================
# LOGGING
# =============================================================================

# log.file: Log filename within log.dir. Set to false to disable file logging.
# Default: rabbit.log
log.file = rabbit.log

# log.dir: Directory for log files.
# Default: /var/log/rabbitmq (package install)
# log.dir = /var/log/rabbitmq

# log.file.level: Minimum severity for file output.
# Default: info
# Options: debug, info, warning, error, critical, none
log.file.level = info

# log.file.rotation.date: Date-based rotation schedule. Uses a cron-like
# syntax; $D0 means rotate daily at midnight.
# Default: not set (no date rotation)
# log.file.rotation.date = $D0

# log.file.rotation.size: Size-based rotation threshold in bytes.
# Default: 0 (no size rotation)
# Set to a reasonable value (e.g., 10485760 = 10MB) to prevent unbounded
# log growth.
log.file.rotation.size = 10485760

# log.file.rotation.count: Number of rotated log files to keep.
# Default: 5
log.file.rotation.count = 5

# log.file.rotation.compress: Gzip-compress rotated log files.
# Default: false
# log.file.rotation.compress = true

# log.console: Enable logging to stdout/stderr. Useful in containers where
# log aggregation reads from stdout.
# Default: false
# log.console = true

# log.console.level: Minimum severity for console output.
# Default: info
# log.console.level = info

# log.exchange: Publish log messages to the amq.rabbitmq.log topic exchange.
# Default: false
# Useful for centralized log collection without touching the filesystem.
# log.exchange = true

# log.exchange.level: Minimum severity for exchange-published logs.
# Default: info
# log.exchange.level = info

# =============================================================================
# QUEUE DEFAULTS
# =============================================================================

# default_queue_type: Queue type used when a client declares a queue without
# specifying x-queue-type.
# Default: classic (RabbitMQ 3.x), quorum (RabbitMQ 4.x)
# Options: classic, quorum
# Quorum queues provide replicated, Raft-based storage with better data safety
# and throughput. Set to quorum for all new deployments.
default_queue_type = quorum

# quorum_queue.initial_cluster_size: Default number of replicas for new quorum
# queues. Can be overridden per-queue with x-quorum-initial-group-size.
# Default: 3 (from rabbit.quorum_cluster_size in advanced.config)
# Should equal or be less than the number of cluster nodes.
# Set via advanced.config: {rabbit, [{quorum_cluster_size, 3}]}

# consumer_timeout: Maximum time (ms) a consumer can hold a delivered message
# without acknowledging before the channel is closed.
# Default: 900000 (15 minutes)
# Prevents stuck consumers from holding messages indefinitely. Increase for
# workloads with legitimately long processing times. Set to infinity to disable
# (not recommended for production).
consumer_timeout = 900000

# max_message_size: Maximum size of a single AMQP message in bytes.
# Default: 16777216 (16 MiB)
# Reduce to prevent oversized messages from consuming excessive memory. The
# absolute maximum is 512 MiB but values above 16 MiB are discouraged.
max_message_size = 16777216

# =============================================================================
# PROTOCOL TUNING
# =============================================================================

# heartbeat: AMQP heartbeat timeout suggested to clients during connection
# negotiation. The actual heartbeat interval is half this value.
# Default: 60 (seconds)
# Set to 0 to disable heartbeats (not recommended; stale connections won't be
# detected). Lower values detect dead connections faster but increase network
# chatter.
heartbeat = 60

# channel_max: Maximum number of AMQP channels per connection.
# Default: 2047
# Reduce to limit per-connection resource usage. Most applications need fewer
# than 100 channels. Set to 0 for unlimited (not recommended).
channel_max = 2047

# frame_max: Maximum AMQP frame size in bytes.
# Default: 131072 (128 KiB)
# Larger frames improve throughput for big messages but increase per-connection
# memory usage.
frame_max = 131072

# handshake_timeout: Maximum time for AMQP protocol handshake after TCP/TLS
# connection is established (ms).
# Default: 10000
handshake_timeout = 10000

# connection_max: Maximum concurrent client connections per node.
# Default: infinity
# Set a limit to protect against connection storms. Requires adequate file
# descriptor limits (see LimitNOFILE in systemd unit).
# connection_max = 5000

# =============================================================================
# MQTT PLUGIN (requires: rabbitmq_mqtt)
# =============================================================================

# mqtt.listeners.tcp.default: Port for unencrypted MQTT connections.
# Default: 1883
# mqtt.listeners.tcp.default = 1883

# mqtt.listeners.ssl.default: Port for TLS-encrypted MQTT connections.
# Default: 8883
# mqtt.listeners.ssl.default = 8883

# mqtt.vhost: Virtual host used for all MQTT connections.
# Default: /
# mqtt.vhost = /

# mqtt.exchange: Exchange that MQTT messages are published to.
# Default: amq.topic
# mqtt.exchange = amq.topic

# mqtt.max_session_expiry_interval_seconds: Maximum MQTT session lifetime.
# Default: 1800 (30 minutes)
# mqtt.max_session_expiry_interval_seconds = 1800

# mqtt.prefetch: Number of QoS 1 messages delivered to an MQTT subscriber
# before requiring acknowledgment.
# Default: 10
# mqtt.prefetch = 10

# mqtt.allow_anonymous: Permit MQTT connections without credentials.
# Default: true
# Set to false in production; require authentication for all MQTT clients.
# mqtt.allow_anonymous = false

# mqtt.durable_queue_type: Queue type backing QoS 1 MQTT subscriptions.
# Default: classic
# Options: classic, quorum
# mqtt.durable_queue_type = quorum

# =============================================================================
# STOMP PLUGIN (requires: rabbitmq_stomp)
# =============================================================================

# stomp.listeners.tcp.default: Port for unencrypted STOMP connections.
# Default: 61613
# stomp.listeners.tcp.default = 61613

# stomp.listeners.ssl.default: Port for TLS-encrypted STOMP connections.
# Default: 61614
# stomp.listeners.ssl.default = 61614

# stomp.default_user / stomp.default_pass: Credentials used for STOMP
# connections that don't send a login/passcode in the CONNECT frame.
# Default: guest / guest
# stomp.default_user = guest
# stomp.default_pass = guest

# stomp.implicit_connect: Allow STOMP clients to skip the CONNECT frame and
# begin sending frames immediately (authenticated as the default user).
# Default: false
# stomp.implicit_connect = false

# =============================================================================
# ERLANG DISTRIBUTION (INTER-NODE)
# =============================================================================

# distribution.listener.port_range: Port range for inter-node communication
# and CLI tool connections.
# Default: 25672-25672 (single port)
# Widen the range only if running multiple RabbitMQ nodes on the same host.
# distribution.listener.port_range.min = 25672
# distribution.listener.port_range.max = 25672

## Deployment Notes

# After editing this file:
#   sudo systemctl restart rabbitmq-server
#   sudo rabbitmq-diagnostics check_running
#   sudo rabbitmq-diagnostics check_local_alarms

# First-time setup:
# 1. Install from official Team RabbitMQ repos (not distro packages)
# 2. Enable management plugin: rabbitmq-plugins enable rabbitmq_management
# 3. Create admin user: rabbitmqctl add_user admin 'StrongPassword'
# 4. Set tags: rabbitmqctl set_user_tags admin administrator
# 5. Set permissions: rabbitmqctl set_permissions -p / admin ".*" ".*" ".*"
# 6. Delete or lock guest: rabbitmqctl delete_user guest

# File descriptor limits:
# The default OS limit (1024) is far too low. Set at least 65536 via:
#   /etc/systemd/system/rabbitmq-server.service.d/limits.conf
#   [Service]
#   LimitNOFILE=65536
# Then: systemctl daemon-reload && systemctl restart rabbitmq-server

# Erlang cookie (clustering):
# All nodes must share the same cookie value in /var/lib/rabbitmq/.erlang.cookie
# (mode 600, owned by rabbitmq). A mismatch causes cryptic "nodedown" errors.
