# Annotated Audit Rules Reference
#
# Place individual rule files in /etc/audit/rules.d/ using the numbering
# convention below. Run `augenrules --load` to merge and activate them.
#
# Numbering convention (from upstream audit-userspace):
#   10-19  Base/kernel config (backlog, failure mode, filters)
#   20-29  Overrides and excludes (reduce noise)
#   30-39  Main policy rules (STIG, PCI-DSS, OSPP, CIS)
#   40-49  Optional / local rules
#   70-79  Edge cases (networking, einval debugging)
#   99     Finalize (immutable flag)
#
# IMPORTANT: Test all rules before enabling immutable mode (-e 2).
# Once -e 2 is active, rules cannot be changed without a reboot.

# ============================================================================
# 10-base-config.rules -- Kernel audit subsystem configuration
# ============================================================================

# Remove any existing rules (clean slate on reload)
-D

# Set the backlog buffer size. Default kernel value is 64, which is far too
# low for production. 8192 handles most workloads; increase for high-throughput
# servers. Events are dropped when backlog is full.
-b 8192

# Failure mode: 0=silent, 1=printk (log warning), 2=panic (halt system).
# Use 1 for most systems. Use 2 only for high-security environments where
# losing audit events is unacceptable (the system will halt rather than drop).
-f 1

# How long the kernel waits (in jiffies, default 60*HZ = 60000) when the
# backlog is full before deciding to drop events. Higher values reduce drops
# at the cost of stalling processes that generate audit events.
--backlog_wait_time 60000

# ============================================================================
# FILE WATCH RULES (-w)
# ============================================================================
# Syntax: -w <path> -p <permissions> -k <key>
#   -p r  = read
#   -p w  = write
#   -p x  = execute
#   -p a  = attribute change (chmod, chown, timestamps)
# Combine permissions: -p wa (write + attribute change)
#
# Watches are syntactic sugar for syscall rules. The kernel converts them
# internally. They monitor the specific inode, so renaming the file and
# creating a new one at the same path will NOT be caught by the old watch.

# --- Identity / Authentication files ---
# Monitor user account databases for unauthorized modifications.
-w /etc/passwd -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/security/opasswd -p wa -k identity

# --- Sudo configuration ---
# Track who modifies sudoers. Attackers often add themselves to gain persistence.
-w /etc/sudoers -p wa -k sudoers
-w /etc/sudoers.d/ -p wa -k sudoers

# --- SSH configuration ---
# Detect sshd config changes that could weaken security (e.g., enabling
# PasswordAuthentication, changing port, adding authorized_keys entries).
-w /etc/ssh/sshd_config -p wa -k sshd_config
-w /etc/ssh/sshd_config.d/ -p wa -k sshd_config

# --- PAM configuration ---
# PAM controls authentication. Changes here can bypass login security.
-w /etc/pam.d/ -p wa -k pam_config

# --- Cron / scheduled tasks ---
# Attackers use cron for persistence. Monitor all cron directories.
-w /etc/crontab -p wa -k cron
-w /etc/cron.d/ -p wa -k cron
-w /etc/cron.daily/ -p wa -k cron
-w /etc/cron.hourly/ -p wa -k cron
-w /etc/cron.weekly/ -p wa -k cron
-w /etc/cron.monthly/ -p wa -k cron
-w /var/spool/cron/ -p wa -k cron

# --- Network configuration ---
-w /etc/hosts -p wa -k network_config
-w /etc/hostname -p wa -k network_config
-w /etc/resolv.conf -p wa -k network_config
-w /etc/NetworkManager/ -p wa -k network_config

# --- Systemd service files ---
# New or modified service files can establish persistence.
-w /etc/systemd/system/ -p wa -k systemd_config
-w /usr/lib/systemd/system/ -p wa -k systemd_config

# --- SELinux / AppArmor ---
-w /etc/selinux/ -p wa -k mac_policy
-w /etc/apparmor/ -p wa -k mac_policy
-w /etc/apparmor.d/ -p wa -k mac_policy

# --- Audit configuration itself ---
# Detect tampering with audit rules or config.
-w /etc/audit/ -p wa -k audit_config
-w /etc/audit/auditd.conf -p wa -k audit_config
-w /etc/audit/rules.d/ -p wa -k audit_config

# --- Login/logout tracking ---
-w /var/log/faillog -p wa -k login_events
-w /var/log/lastlog -p wa -k login_events
-w /var/log/tallylog -p wa -k login_events
-w /var/run/utmp -p wa -k login_events
-w /var/log/wtmp -p wa -k login_events
-w /var/log/btmp -p wa -k login_events

# ============================================================================
# SYSCALL RULES (-a always,exit -S ...)
# ============================================================================
# Syntax: -a <action>,<list> -F arch=<arch> -S <syscall> -F <field>=<value> -k <key>
#
# Action: always (log it) or never (suppress it)
# List: exit (evaluated on syscall exit -- most common), task, user, exclude
#
# IMPORTANT: Always specify -F arch=b64 AND create a paired -F arch=b32 rule
# for the same syscalls. Syscall numbers differ between 32-bit and 64-bit.
#
# Common filter fields:
#   -F auid>=1000        Only real (human) user accounts
#   -F auid!=-1          Exclude processes with unset login UID (system services)
#   -F euid=0            Effective UID is root (privilege escalation)
#   -F exit=-EACCES      Failed with "permission denied"
#   -F exit=-EPERM       Failed with "operation not permitted"
#   -F success=0         Only failed operations
#   -F success=1         Only successful operations
#   -F path=/some/file   Specific file (alternative to -w for syscall rules)
#   -F dir=/some/dir     Recursive directory watch
#   -F exe=/usr/bin/cmd  Specific executable triggered the syscall

# --- Time changes ---
# Detecting unauthorized time changes is required by PCI-DSS 10.4 and STIG.
-a always,exit -F arch=b64 -S adjtimex -S settimeofday -S clock_settime -k time_change
-a always,exit -F arch=b32 -S adjtimex -S settimeofday -S clock_settime -S stime -k time_change
-w /etc/localtime -p wa -k time_change

# --- User/group modification ---
# Track account creation, deletion, modification.
-a always,exit -F arch=b64 -S setuid -S setgid -S setreuid -S setregid -S setresuid -S setresgid -k privilege_change
-a always,exit -F arch=b32 -S setuid -S setgid -S setreuid -S setregid -S setresuid -S setresgid -k privilege_change

# --- Kernel module loading ---
# Detect rootkit installation via kernel modules.
-a always,exit -F arch=b64 -S init_module -S finit_module -S delete_module -F auid!=-1 -k modules
-a always,exit -F arch=b32 -S init_module -S finit_module -S delete_module -F auid!=-1 -k modules

# --- Mount operations ---
# Track filesystem mounts (data exfiltration via removable media).
-a always,exit -F arch=b64 -S mount -S umount2 -F auid>=1000 -F auid!=-1 -k mounts
-a always,exit -F arch=b32 -S mount -S umount -S umount2 -F auid>=1000 -F auid!=-1 -k mounts

# --- File deletion by users ---
# Track file deletion for forensic investigations.
-a always,exit -F arch=b64 -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=-1 -k file_delete
-a always,exit -F arch=b32 -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=-1 -k file_delete

# --- Unauthorized access attempts (failed opens) ---
# Detect brute-force file access and permission probing.
-a always,exit -F arch=b64 -S open -S openat -S creat -F exit=-EACCES -F auid>=1000 -F auid!=-1 -k access_denied
-a always,exit -F arch=b64 -S open -S openat -S creat -F exit=-EPERM -F auid>=1000 -F auid!=-1 -k access_denied
-a always,exit -F arch=b32 -S open -S openat -S creat -F exit=-EACCES -F auid>=1000 -F auid!=-1 -k access_denied
-a always,exit -F arch=b32 -S open -S openat -S creat -F exit=-EPERM -F auid>=1000 -F auid!=-1 -k access_denied

# --- Command execution by root ---
# Log every command executed with root effective UID.
-a always,exit -F arch=b64 -F euid=0 -S execve -k rootcmd
-a always,exit -F arch=b32 -F euid=0 -S execve -k rootcmd

# --- Permission changes ---
# Detect chmod/chown modifications.
-a always,exit -F arch=b64 -S chmod -S fchmod -S fchmodat -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b32 -S chmod -S fchmod -S fchmodat -F auid>=1000 -F auid!=-1 -k perm_mod
-a always,exit -F arch=b64 -S chown -S fchown -S fchownat -S lchown -F auid>=1000 -F auid!=-1 -k owner_mod
-a always,exit -F arch=b32 -S chown -S fchown -S fchownat -S lchown -F auid>=1000 -F auid!=-1 -k owner_mod

# --- Extended attribute changes ---
-a always,exit -F arch=b64 -S setxattr -S lsetxattr -S fsetxattr -S removexattr -S lremovexattr -S fremovexattr -F auid>=1000 -F auid!=-1 -k xattr_mod
-a always,exit -F arch=b32 -S setxattr -S lsetxattr -S fsetxattr -S removexattr -S lremovexattr -S fremovexattr -F auid>=1000 -F auid!=-1 -k xattr_mod

# ============================================================================
# PRIVILEGE ESCALATION MONITORING
# ============================================================================

# Monitor execution of privileged commands (setuid/setgid binaries).
# These rules use -F exe= to target specific binaries.
-w /usr/bin/sudo -p x -k priv_esc
-w /usr/bin/su -p x -k priv_esc
-w /usr/bin/chsh -p x -k priv_esc
-w /usr/bin/chfn -p x -k priv_esc
-w /usr/bin/passwd -p x -k priv_esc
-w /usr/bin/gpasswd -p x -k priv_esc
-w /usr/bin/newgrp -p x -k priv_esc
-w /usr/sbin/usermod -p x -k priv_esc
-w /usr/sbin/useradd -p x -k priv_esc
-w /usr/sbin/userdel -p x -k priv_esc
-w /usr/sbin/groupadd -p x -k priv_esc
-w /usr/sbin/groupmod -p x -k priv_esc
-w /usr/sbin/groupdel -p x -k priv_esc

# ============================================================================
# 99-finalize.rules -- Lock down (MUST be last)
# ============================================================================

# Make the configuration immutable. No rule changes until reboot.
# ONLY enable this after all rules are tested and verified.
# -e 2
