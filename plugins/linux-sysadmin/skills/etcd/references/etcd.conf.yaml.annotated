# Annotated etcd.conf.yml
# Each directive includes: what it does, default value, and when to change it.
# Place this file at /etc/etcd/etcd.conf.yml (or pass via --config-file flag).
#
# After changes: sudo systemctl restart etcd
# Env var alternative: every YAML key maps to ETCD_ + uppercase + underscores
#   (e.g., data-dir -> ETCD_DATA_DIR, listen-client-urls -> ETCD_LISTEN_CLIENT_URLS)
# Config precedence: command-line flag > environment variable > config file

# ---------------------------------------------------------------------------
# MEMBER
# ---------------------------------------------------------------------------

# Human-readable name for this member. Used in logging and as the default
# data directory name (${name}.etcd) when data-dir is unset.
# Default: "default"  |  Change when: running a multi-node cluster (use
#   hostnames or node identifiers like "etcd-node-1").
name: 'etcd-node-1'

# Filesystem path where etcd stores its WAL and snapshot data. Must be on
# fast storage (SSD strongly recommended; etcd needs 50+ sequential IOPS,
# ideally 500+). The etcd user must own this directory.
# Default: "${name}.etcd"  |  Change when: you want a stable, absolute path
#   that doesn't depend on the member name.
data-dir: '/var/lib/etcd'

# Separate directory for write-ahead log files. Placing the WAL on a
# dedicated disk reduces write contention between WAL appends and snapshot I/O.
# Default: "" (WAL stored inside data-dir)  |  Change when: you have a
#   second SSD and want to isolate WAL I/O from snapshot and compaction I/O.
# wal-dir: ''

# Number of committed transactions that trigger a snapshot to disk. Snapshots
# compact the in-memory Raft log. Lower values snapshot more often (more disk
# I/O, faster recovery). Higher values reduce I/O but increase recovery time.
# Default: 100000 (changed from 10000 in v3.2)
# Change when: slow disks struggle with frequent snapshots, or you want
#   faster crash recovery at the cost of more disk writes.
snapshot-count: 100000

# Raft heartbeat interval in milliseconds. The leader sends heartbeats at
# this interval to maintain authority. Must be significantly less than
# election-timeout.
# Default: 100  |  Change when: high-latency networks need longer intervals,
#   but never exceed 1/10th of election-timeout.
heartbeat-interval: 100

# Raft election timeout in milliseconds. If a follower receives no heartbeat
# within this window, it starts a new leader election. Must be at least
# 5× heartbeat-interval per etcd guidance.
# Default: 1000  |  Change when: high-latency or cross-datacenter links
#   cause spurious elections. Typical range: 1000-50000.
election-timeout: 1000

# Backend storage quota in bytes. When any member's DB file exceeds this,
# the entire cluster raises a NOSPACE alarm and rejects all writes until
# you compact, defragment, and disarm the alarm.
# Default: 0 (uses the built-in 2 GiB limit)
# Suggested maximum: 8 GiB (8589934592). etcd warns at startup if you set
#   it higher. Change when: your workload stores more than 2 GB of key-value
#   data (common in large Kubernetes clusters).
quota-backend-bytes: 8589934592

# ---------------------------------------------------------------------------
# NETWORKING — CLIENT
# ---------------------------------------------------------------------------

# Comma-separated list of URLs this member listens on for client traffic
# (etcdctl, kube-apiserver, application clients). Use 0.0.0.0 to bind all
# interfaces, or a specific IP to restrict access.
# Default: "http://localhost:2379"  |  Change when: clients connect from
#   other hosts, or you enable TLS (change http:// to https://).
listen-client-urls: 'https://0.0.0.0:2379'

# Comma-separated list of client URLs this member advertises to the cluster
# and to clients for redirection. Must be reachable by external clients.
# Never use localhost or 0.0.0.0 here in a multi-node cluster.
# Default: "http://localhost:2379"  |  Change when: running a cluster or
#   when the listen address differs from the externally reachable address.
advertise-client-urls: 'https://10.0.1.10:2379'

# ---------------------------------------------------------------------------
# NETWORKING — PEER
# ---------------------------------------------------------------------------

# Comma-separated list of URLs this member listens on for peer (Raft)
# traffic from other cluster members. Separate from client URLs.
# Default: "http://localhost:2380"  |  Change when: running a multi-node
#   cluster (bind to the node's IP and use https:// when TLS is configured).
listen-peer-urls: 'https://0.0.0.0:2380'

# Comma-separated list of peer URLs this member advertises to other members.
# Must be reachable by all peers. Never use localhost or 0.0.0.0.
# Default: "http://localhost:2380"  |  Change when: always set this
#   explicitly in multi-node clusters.
initial-advertise-peer-urls: 'https://10.0.1.10:2380'

# ---------------------------------------------------------------------------
# CLUSTERING
# ---------------------------------------------------------------------------

# Comma-separated list of member-name=peer-url pairs defining the initial
# cluster membership. Every member in the cluster must list the same set.
# Default: "default=http://localhost:2380"
# Change when: bootstrapping a new cluster with known members.
initial-cluster: 'etcd-node-1=https://10.0.1.10:2380,etcd-node-2=https://10.0.1.11:2380,etcd-node-3=https://10.0.1.12:2380'

# Whether this is a brand-new cluster ("new") or the member is joining an
# existing cluster ("existing"). Using "new" on an existing data directory
# causes the error "member X has already been bootstrapped."
# Default: "new"  |  Change to "existing" when adding a member to a running
#   cluster, or when a member restarts after a data directory wipe.
initial-cluster-state: 'new'

# Shared token that prevents members of different clusters from accidentally
# joining each other during bootstrap. Only matters during initial formation;
# ignored after the cluster is established.
# Default: "etcd-cluster"  |  Change when: you run multiple etcd clusters in
#   the same network and want to prevent accidental cross-join.
initial-cluster-token: 'my-etcd-cluster'

# ---------------------------------------------------------------------------
# AUTO-COMPACTION
# ---------------------------------------------------------------------------

# How to interpret auto-compaction-retention: "periodic" treats the value as
# a time duration (e.g., "1" = 1 hour); "revision" treats it as a revision
# count (e.g., "1000" = keep the last 1000 revisions).
# Default: "periodic"  |  Change when: you want revision-based compaction
#   (less common; useful when write rate varies widely).
auto-compaction-mode: 'periodic'

# Retention window for auto-compaction. With periodic mode, this is hours
# (e.g., "1" = compact revisions older than 1 hour). With revision mode,
# this is a revision count. Set to "0" to disable auto-compaction entirely.
# Default: "0" (disabled)  |  Change when: you want etcd to automatically
#   reclaim old revision history. Recommended: "1" (1 hour) for most
#   production clusters to prevent unbounded DB growth.
# NOTE: compaction marks old revisions as reclaimable, but the BoltDB file
#   doesn't shrink until you defragment (etcdctl defrag).
auto-compaction-retention: '1'

# ---------------------------------------------------------------------------
# CLIENT TRANSPORT SECURITY (TLS)
# ---------------------------------------------------------------------------

# TLS settings for client-to-member communication (port 2379).
# All four fields are needed for mutual TLS. For server-only TLS (clients
# don't present certificates), set cert-file and key-file only.
client-transport-security:

  # Path to the PEM-encoded server certificate presented to clients.
  # Default: "" (TLS disabled)  |  Change when: enabling TLS for client
  #   connections (strongly recommended for production).
  cert-file: '/etc/etcd/pki/server.crt'

  # Path to the PEM-encoded private key matching cert-file.
  # Default: ""  |  Must be set whenever cert-file is set.
  key-file: '/etc/etcd/pki/server.key'

  # Path to the PEM-encoded CA certificate used to verify client certificates.
  # Required when client-cert-auth is true.
  # Default: ""  |  Change when: enforcing mutual TLS (mTLS).
  trusted-ca-file: '/etc/etcd/pki/ca.crt'

  # Require clients to present a valid certificate signed by trusted-ca-file.
  # Without this, TLS is server-authenticated only (clients verify the server,
  # but the server accepts any client).
  # Default: false  |  Change when: you want mutual TLS (recommended for
  #   production, especially when etcd is exposed beyond localhost).
  client-cert-auth: true

  # Generate self-signed certificates automatically. Convenient for testing
  # but unsuitable for production (no CA chain, no revocation, no SANs control).
  # Default: false  |  Change when: quick dev/test setup without real certs.
  # auto-tls: false

# ---------------------------------------------------------------------------
# PEER TRANSPORT SECURITY (TLS)
# ---------------------------------------------------------------------------

# TLS settings for member-to-member (Raft) communication (port 2380).
# Same structure as client-transport-security. In production, always enable
# peer TLS to prevent rogue members from joining the cluster.
peer-transport-security:

  # Path to the PEM-encoded certificate for peer communication.
  # Default: ""  |  Change when: enabling peer TLS (recommended for
  #   any multi-node cluster).
  cert-file: '/etc/etcd/pki/peer.crt'

  # Path to the PEM-encoded private key matching the peer cert.
  # Default: ""  |  Must be set whenever cert-file is set.
  key-file: '/etc/etcd/pki/peer.key'

  # CA certificate to verify peer certificates. All members must be signed
  # by the same CA.
  # Default: ""  |  Change when: enforcing mutual peer TLS.
  trusted-ca-file: '/etc/etcd/pki/ca.crt'

  # Require peers to present valid certificates. Without this, any node
  # can join the cluster over TLS without proving its identity.
  # Default: false  |  Change when: always enable in production to prevent
  #   unauthorized members.
  client-cert-auth: true

  # Generate self-signed peer certificates automatically.
  # Default: false  |  Change when: testing multi-node without real certs.
  # auto-tls: false

  # Restrict peer connections to certificates with this Common Name (CN).
  # Default: ""  |  Change when: you want an additional layer of identity
  #   verification beyond CA signing.
  # allowed-cn: ''

  # Restrict peer connections to certificates with this hostname in the SAN.
  # Default: ""  |  Change when: using SAN-based identity instead of CN.
  # allowed-hostname: ''

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------

# Logging implementation. Only "zap" is supported in v3.5+. Older versions
# supported "capnslog" (removed in v3.5).
# Default: "zap"  |  No reason to change this.
logger: 'zap'

# Minimum severity level for log messages.
# Valid values: debug, info, warn, error, panic, fatal
# Default: "info"  |  Change when: debugging cluster issues (use "debug")
#   or reducing log volume in stable production (use "warn").
log-level: 'info'

# Where log output is sent. Comma-separated list of destinations.
# Valid values: "stderr", "stdout", file paths, "default" (stderr under systemd)
# Default: "default"  |  Change when: you want to log to a file in addition
#   to or instead of stderr.
# log-outputs: [stderr]

# ---------------------------------------------------------------------------
# ADDITIONAL OPTIONS (commonly tuned)
# ---------------------------------------------------------------------------

# Maximum number of snapshot files to retain on disk. Older snapshots are
# deleted automatically. 0 means unlimited.
# Default: 5  |  Change when: you want more snapshot history for debugging
#   or tighter disk usage.
# max-snapshots: 5

# Maximum number of WAL files to retain. 0 means unlimited.
# Default: 5  |  Change when: same rationale as max-snapshots.
# max-wals: 5

# Enable runtime profiling data via HTTP. Useful for debugging performance
# issues with pprof. Exposed at /debug/pprof/ on the client URL.
# Default: false  |  Change when: diagnosing CPU or memory issues.
# enable-pprof: false

# Reject reconfiguration requests that would cause quorum loss.
# Default: true in v3.5+ (was false in v3.4)
# Change when: almost never. Disabling risks cluster unavailability during
#   membership changes.
# strict-reconfig-check: true

# Force this member to create a new single-node cluster from its existing
# data. Destroys cluster membership information. Use only as a last resort
# for disaster recovery when quorum is permanently lost.
# Default: false  |  Change when: restoring a single node from a snapshot
#   after total cluster loss.
# force-new-cluster: false

# TLS cipher suites. Restricts which ciphers the server will negotiate.
# Default: all supported suites
# Change when: compliance requires specific ciphers. Example secure set:
# cipher-suites:
#   - TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256
#   - TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
#   - TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256
#   - TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384

# Minimum TLS version for all TLS connections (client and peer).
# Default: "TLS1.2"  |  Change when: enforcing TLS 1.3 only.
# tls-min-version: 'TLS1.2'

# Maximum TLS version.
# Default: "TLS1.3"  |  Rarely changed. Lower only if a buggy client
#   can't handle TLS 1.3.
# tls-max-version: 'TLS1.3'
