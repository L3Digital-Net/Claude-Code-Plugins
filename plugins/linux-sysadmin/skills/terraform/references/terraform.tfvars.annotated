# terraform.tfvars — Annotated Variable Definitions
#
# Location: project root alongside *.tf files
# Terraform loads terraform.tfvars and *.auto.tfvars automatically.
# Other files require: terraform plan -var-file=staging.tfvars
#
# SECURITY: Never commit files containing secrets to version control.
# Add sensitive .tfvars to .gitignore and pass secrets via TF_VAR_* env vars
# or a secrets manager instead.

# ---------------------------------------------------------------------------
# STRING VARIABLES
# ---------------------------------------------------------------------------

# Simple string. Matching variable block in variables.tf:
#   variable "project_name" {
#     type        = string
#     description = "Project identifier used in resource naming"
#   }
project_name = "my-web-app"

# Strings that look like other types are still strings in .tfvars.
# Terraform converts based on the declared variable type.
aws_region = "us-east-1"

# ---------------------------------------------------------------------------
# NUMBER VARIABLES
# ---------------------------------------------------------------------------

# Integers and floats are both valid number values.
#   variable "instance_count" {
#     type    = number
#     default = 1
#     validation {
#       condition     = var.instance_count >= 1 && var.instance_count <= 20
#       error_message = "Must be between 1 and 20."
#     }
#   }
instance_count = 3

# ---------------------------------------------------------------------------
# BOOLEAN VARIABLES
# ---------------------------------------------------------------------------

# Booleans: true or false (unquoted). Quoted "true" is a string, not a bool.
#   variable "enable_monitoring" {
#     type    = bool
#     default = true
#   }
enable_monitoring = true
create_dns_record = false

# ---------------------------------------------------------------------------
# LIST VARIABLES
# ---------------------------------------------------------------------------

# Lists are ordered sequences. The variable type determines element type.
#   variable "availability_zones" {
#     type        = list(string)
#     description = "AZs to deploy into"
#   }
availability_zones = [
  "us-east-1a",
  "us-east-1b",
  "us-east-1c",
]

# List of numbers:
#   variable "allowed_ports" {
#     type = list(number)
#   }
allowed_ports = [80, 443, 8080]

# ---------------------------------------------------------------------------
# MAP VARIABLES
# ---------------------------------------------------------------------------

# Maps are key-value pairs. Keys are always strings.
#   variable "common_tags" {
#     type        = map(string)
#     description = "Tags applied to all resources"
#   }
common_tags = {
  Environment = "production"
  Team        = "platform"
  ManagedBy   = "terraform"
  CostCenter  = "12345"
}

# ---------------------------------------------------------------------------
# OBJECT VARIABLES (structured types)
# ---------------------------------------------------------------------------

# Objects define a fixed schema with named attributes and specific types.
#   variable "database_config" {
#     type = object({
#       engine         = string
#       engine_version = string
#       instance_class = string
#       storage_gb     = number
#       multi_az       = bool
#       backup_days    = number
#     })
#     validation {
#       condition     = contains(["mysql", "postgres", "mariadb"], var.database_config.engine)
#       error_message = "Engine must be mysql, postgres, or mariadb."
#     }
#   }
database_config = {
  engine         = "postgres"
  engine_version = "16.2"
  instance_class = "db.t3.medium"
  storage_gb     = 100
  multi_az       = true
  backup_days    = 7
}

# ---------------------------------------------------------------------------
# COMPLEX NESTED STRUCTURES
# ---------------------------------------------------------------------------

# Map of objects: each key maps to a structured value.
#   variable "services" {
#     type = map(object({
#       port          = number
#       health_path   = string
#       desired_count = number
#       cpu           = number
#       memory        = number
#     }))
#   }
services = {
  api = {
    port          = 8080
    health_path   = "/health"
    desired_count = 3
    cpu           = 512
    memory        = 1024
  }
  worker = {
    port          = 9090
    health_path   = "/ready"
    desired_count = 2
    cpu           = 256
    memory        = 512
  }
}

# ---------------------------------------------------------------------------
# SENSITIVE VARIABLES — DO NOT PUT REAL SECRETS HERE
# ---------------------------------------------------------------------------

# These are declared with sensitive = true in variables.tf.
# Terraform suppresses their values in plan/apply output but
# STORES THEM IN PLAIN TEXT in the state file.
#
# Best practice: do NOT define sensitive values in .tfvars files.
# Instead use one of:
#   1. Environment variables:     export TF_VAR_db_password="secret"
#   2. CLI flag:                  terraform apply -var="db_password=secret"
#   3. Secrets manager data source (AWS SSM, Vault, etc.)
#   4. OpenTofu state encryption (tofu 1.7+) for state-level protection
#
#   variable "db_password" {
#     type      = string
#     sensitive = true
#   }

# db_password = "DO_NOT_COMMIT_REAL_PASSWORDS"

# ---------------------------------------------------------------------------
# VARIABLE PRECEDENCE (highest to lowest)
# ---------------------------------------------------------------------------
#
# 1. -var="key=value" on the command line
# 2. -var-file=filename.tfvars on the command line
# 3. *.auto.tfvars or *.auto.tfvars.json (alphabetical order)
# 4. terraform.tfvars or terraform.tfvars.json
# 5. TF_VAR_<name> environment variables
# 6. default value in the variable block
# 7. Interactive prompt (if no default and TF_INPUT is not false)
