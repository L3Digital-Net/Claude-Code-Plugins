# Annotated ceph.conf
# Each directive includes: what it does, default value, recommended value,
# and when to change it. Options are organized by config section.
#
# Since Mimic (v13), Ceph maintains a central config database in the monitors.
# Most runtime options can be set with:
#   ceph config set <daemon-type> <option> <value>
# The ceph.conf file is still needed for bootstrap options (fsid, mon_host)
# and any settings that must be present before the monitors are reachable.
#
# Config path: /etc/ceph/ceph.conf
# After editing, restart affected daemons:
#   sudo systemctl restart ceph-mon@<id>
#   sudo systemctl restart ceph-osd@<id>
# Or for cephadm-managed clusters:
#   sudo ceph orch daemon restart <type>.<id>
#
# Option names accept both underscores and dashes interchangeably
# (e.g., mon_host and mon-host are equivalent).

# ===========================================================================
# [global] — Settings that apply to all daemons and clients
# ===========================================================================

[global]

# Unique cluster identifier. Generated automatically by cephadm bootstrap.
# Every daemon and client must use the same fsid to communicate.
# Default: none (must be set)  |  Format: UUID
# Change when: never — this is set once at cluster creation.
fsid = a1b2c3d4-e5f6-7890-abcd-ef1234567890

# Hostnames of the initial monitor daemons for bootstrapping quorum.
# Comma-separated short hostnames (matching `hostname -s` on each monitor).
# Default: none  |  Recommended: list all initial monitors
# Change when: bootstrap. After the cluster is running, monitor membership
#   is managed via `ceph mon add/remove`, not this setting.
mon_initial_members = mon1, mon2, mon3

# Network addresses of monitor daemons. Clients and daemons use this to
# find the monitors. Supports v2 (msgr2, port 3300) and v1 (legacy, port 6789).
# Default: none  |  Recommended: list all monitor IPs with both protocol versions
# Format: [v2:IP:3300,v1:IP:6789] or just IP addresses (auto-detects ports)
# Change when: monitors are added, removed, or change IP addresses.
mon_host = [v2:10.0.0.1:3300/0,v1:10.0.0.1:6789/0],[v2:10.0.0.2:3300/0,v1:10.0.0.2:6789/0],[v2:10.0.0.3:3300/0,v1:10.0.0.3:6789/0]

# Public (front-side) network for client-to-cluster communication. All client
# I/O (RBD, CephFS, RGW) traverses this network. CIDR notation.
# Default: none  |  Recommended: always set explicitly
# Change when: initial deployment. Ensure all MON, OSD, MDS, and client
#   nodes can reach each other on this network.
public_network = 10.0.0.0/24

# Cluster (back-side) network for OSD replication, heartbeats, backfill,
# and recovery traffic. Separating this from public_network prevents
# replication I/O from competing with client traffic.
# Default: not set (uses public_network for everything)
# Recommended: a dedicated network for production clusters with significant
#   replication traffic.
# Change when: you have a second NIC or VLAN dedicated to inter-OSD traffic.
# cluster_network = 10.0.1.0/24

# ---------------------------------------------------------------------------
# Authentication (CephX)
# ---------------------------------------------------------------------------

# Authentication protocol required for cluster-internal communication
# (between daemons). cephx enables authentication; none disables it.
# Default: cephx  |  Recommended: cephx (never disable in production)
# Change when: never in production. Disabling removes all access control.
auth_cluster_required = cephx

# Authentication protocol required for clients accessing Ceph services.
# Default: cephx  |  Recommended: cephx
auth_service_required = cephx

# Authentication protocol required for Ceph services authenticating back
# to clients (verifies the cluster's identity to the client).
# Default: cephx  |  Recommended: cephx
auth_client_required = cephx

# ---------------------------------------------------------------------------
# Pool Defaults
# ---------------------------------------------------------------------------

# Default replication count for new pools. Each object is written to N OSDs.
# Default: 3  |  Recommended: 3 (tolerates 1 OSD failure)
# Change when: you have fewer than 3 OSDs (set to 2 for small test clusters)
#   or want higher durability (set to 4+ for critical data).
#   Per-pool override: ceph osd pool set <pool> size <N>
osd_pool_default_size = 3

# Minimum number of replicas that must be available for a pool to accept
# writes in a degraded state.
# Default: 0 (auto-calculates as size - floor(size/2), so 2 for size=3)
# Recommended: leave at 0 (auto) or set to 2 for size=3
# Change when: you need stricter write availability guarantees. Setting
#   min_size=1 allows writes with only one copy (risks data loss on failure).
osd_pool_default_min_size = 0

# Default number of placement groups for new pools when PG autoscaler is off.
# Default: 32  |  Recommended: let the PG autoscaler handle this (see below)
# Change when: PG autoscaling is disabled and you need manual PG counts.
#   Too few PGs = uneven data distribution; too many = excessive memory per OSD.
# osd_pool_default_pg_num = 32

# PG autoscaler mode for new pools.
# Default: on  |  Accepted: on, off, warn
# Recommended: on — the autoscaler adjusts PG counts based on pool usage
# Change when: you want manual PG management (set to off) or just warnings
#   without automatic adjustment (set to warn).
osd_pool_default_pg_autoscale_mode = on

# ---------------------------------------------------------------------------
# CRUSH Topology
# ---------------------------------------------------------------------------

# CRUSH leaf type for chooseleaf rule. Determines the failure domain.
# 0 = osd (single-node test), 1 = host (default; one replica per host),
# 2 = chassis, 3 = rack, 4 = row, 5 = pdu, 6 = pod, 7 = room,
# 8 = datacenter, 9 = zone, 10 = region, 11 = root
# Default: 1 (host)  |  Recommended: 1 for most deployments
# Change when: you have a single-node test cluster (set to 0) or want
#   rack-level fault tolerance (set to 3, requires 3+ racks).
osd_crush_chooseleaf_type = 1

# ===========================================================================
# [mon] — Monitor daemon settings
# ===========================================================================

[mon]

# Raise HEALTH_WARN when a monitor's data filesystem has less than this
# percentage of free space.
# Default: 30 (percent)  |  Recommended: 30
# Change when: your monitor stores are on large partitions where 30% free
#   represents more space than needed, or small partitions that fill quickly.
mon_data_avail_warn = 30

# Raise HEALTH_ERR (critical) when a monitor's filesystem drops below this
# percentage of free space.
# Default: 5 (percent)  |  Recommended: 5
# Change when: rarely. 5% is already dangerously low for a monitor store.
mon_data_avail_crit = 5

# Threshold (ratio 0.0-1.0) at which an OSD is marked "full" and the
# entire cluster stops accepting writes to prevent data loss.
# Default: 0.95 (95%)  |  Recommended: 0.95
# Change when: emergency situations where you need to temporarily raise the
#   threshold to regain write access while adding capacity.
#   Runtime: ceph osd set-full-ratio 0.97
mon_osd_full_ratio = 0.95

# Threshold at which an OSD is marked "nearfull". Triggers HEALTH_WARN.
# Default: 0.85 (85%)  |  Recommended: 0.85
# Change when: you want earlier or later warnings. The gap between nearfull
#   and full is your response window for adding capacity.
mon_osd_nearfull_ratio = 0.85

# Threshold at which an OSD is considered too full to be a backfill target.
# Prevents the cluster from filling an already-busy OSD during recovery.
# Default: 0.90 (90%)  |  Recommended: 0.90
mon_osd_backfillfull_ratio = 0.90

# Seconds to wait before marking an unresponsive OSD as "out" (triggering
# data migration to remaining OSDs). Too short causes unnecessary rebalancing
# for transient failures; too long delays recovery.
# Default: 600 (10 minutes)  |  Recommended: 600
# Change when: you want faster automatic recovery (lower) or want to avoid
#   unnecessary rebalancing during maintenance windows (raise or set noout flag).
mon_osd_down_out_interval = 600

# Allow pool deletion. Disabled by default as a safety measure against
# accidental data loss.
# Default: false  |  Recommended: false (enable temporarily when needed)
# Change when: you need to delete a pool. Set to true, delete, then set
#   back to false. Runtime: ceph config set mon mon_allow_pool_delete true
mon_allow_pool_delete = false

# ===========================================================================
# [osd] — Object Storage Daemon settings
# ===========================================================================

[osd]

# Journal size in MB. Only relevant for FileStore (legacy). BlueStore (the
# default since Luminous) does not use a separate journal.
# Default: 5120 (5 GB)  |  Recommended: 5120 for FileStore; irrelevant for BlueStore
# Change when: using FileStore with SSDs (can reduce to 1024) or spinning
#   disks with heavy write load (increase to 10240).
osd_journal_size = 5120

# Maximum concurrent recovery operations per OSD. 0 means use the
# device-specific defaults (osd_recovery_max_active_hdd / _ssd).
# Default: 0  |  Recommended: 0 (let Ceph auto-select based on device type)
# Change when: you need to override device-specific defaults globally.
osd_recovery_max_active = 0

# Maximum concurrent recovery operations for HDD-backed OSDs.
# Default: 3  |  Recommended: 3
# Change when: recovery is too slow and the cluster has I/O headroom (raise)
#   or recovery I/O is impacting client performance (lower).
osd_recovery_max_active_hdd = 3

# Maximum concurrent recovery operations for SSD-backed OSDs.
# Default: 10  |  Recommended: 10
# Change when: SSDs can handle more parallel recovery (raise to 15-20).
osd_recovery_max_active_ssd = 10

# Maximum number of backfills allowed to or from a single OSD simultaneously.
# Default: 1  |  Recommended: 1 for HDD; 2-4 for SSD
# Change when: you want faster rebalancing after adding/removing OSDs.
osd_max_backfills = 1

# Priority of recovery operations relative to client operations.
# Lower = less priority. Range: 1-63.
# Default: 3  |  Recommended: 3
# Change when: you want recovery to complete faster at the cost of client
#   latency (raise to 10-20) or minimize recovery impact (lower to 1).
osd_recovery_op_priority = 3

# ---------------------------------------------------------------------------
# BlueStore (default OSD backend since Luminous)
# ---------------------------------------------------------------------------

# Target heap memory usage per OSD daemon when auto-tuning is enabled.
# The auto-tuner adjusts BlueStore cache sizes to stay within this budget.
# Default: 4294967296 (4 GB)  |  Minimum: 939524096 (896 MB)
# Recommended: 4 GB; set lower on memory-constrained nodes
# Change when: tuning memory usage. A node with 12 OSDs at 4 GB each
#   needs 48 GB RAM just for OSD processes. Reduce to 2-3 GB per OSD
#   on nodes with limited RAM, but expect reduced cache hit rates.
osd_memory_target = 4294967296

# Minimum cache size per OSD when auto-tuning. The auto-tuner will not
# shrink the cache below this value.
# Default: 134217728 (128 MB)  |  Recommended: 128 MB
osd_memory_cache_min = 134217728

# Enable automatic tuning of BlueStore cache ratios. The auto-tuner
# adjusts the split between metadata cache, KV cache, and data cache
# based on workload patterns.
# Default: true  |  Recommended: true
# Change when: you want fixed cache ratios (set to false and configure
#   bluestore_cache_meta_ratio / bluestore_cache_kv_ratio manually).
bluestore_cache_autotune = true

# Total BlueStore cache size override. 0 means use the device-type defaults.
# Default: 0 (auto: 1 GB for HDD, 3 GB for SSD)
# Recommended: 0 (let auto-tuning manage it via osd_memory_target)
# Change when: you want to override auto-tuning with a fixed cache size.
bluestore_cache_size = 0

# Default cache sizes by device type (used when bluestore_cache_size=0
# and auto-tuning is disabled).
# bluestore_cache_size_hdd = 1073741824   # 1 GB
# bluestore_cache_size_ssd = 3221225472   # 3 GB

# Checksum algorithm for data integrity verification.
# Default: crc32c  |  Accepted: none, crc32c, crc32c_16, crc32c_8, xxhash32, xxhash64
# Recommended: crc32c (fast with hardware acceleration on modern CPUs)
# Change when: you need stronger checksums (xxhash64) or want to disable
#   checksumming for maximum throughput (not recommended).
bluestore_csum_type = crc32c

# Compression mode for BlueStore. Controls when data is compressed.
#   none: never compress. passive: compress only if client requests it.
#   aggressive: compress unless client requests no compression.
#   force: always compress.
# Default: none  |  Recommended: none (enable per-pool if needed)
# Change when: storage capacity is more constrained than CPU. Enable
#   per-pool: ceph osd pool set <pool> compression_mode aggressive
bluestore_compression_mode = none

# Compression algorithm.
# Default: snappy  |  Accepted: snappy, zlib, zstd, lz4
# Recommended: snappy (fast, moderate ratio) or zstd (better ratio, more CPU)
# Change when: you enable compression and want to tune the speed/ratio tradeoff.
bluestore_compression_algorithm = snappy

# Minimum allocation size. Determines the smallest I/O unit. Writes smaller
# than this are padded, wasting some space but avoiding read-modify-write.
# Default: 0 (auto: 4 KB for both HDD and SSD)
# Change when: using QLC SSDs with large internal block sizes (raise to 16K-64K).
# bluestore_min_alloc_size = 0
# bluestore_min_alloc_size_hdd = 4096
# bluestore_min_alloc_size_ssd = 4096

# ---------------------------------------------------------------------------
# Scrubbing (data integrity verification)
# ---------------------------------------------------------------------------

# Restrict scrubbing to specific hours (24h format). 0/0 means no restriction.
# Default: 0 (start) / 0 (end)  |  Recommended: restrict to off-peak hours
# Change when: scrub I/O impacts client performance during business hours.
osd_scrub_begin_hour = 0
osd_scrub_end_hour = 0

# Interval between deep scrubs (reads and verifies all data, not just metadata).
# Default: 604800 (7 days)  |  Recommended: 604800
# Change when: you want more frequent integrity checks (lower) or have large
#   volumes that cannot complete deep scrub in a week (raise cautiously).
osd_deep_scrub_interval = 604800

# Sleep time in seconds between scrubbing object groups. Throttles scrub I/O.
# Default: 0.0 (no sleep)  |  Recommended: 0.1 for production
# Change when: scrubbing causes noticeable client latency. Increase to
#   slow down scrubbing at the cost of longer total scrub time.
osd_scrub_sleep = 0.0

# ===========================================================================
# [mds] — Metadata Server settings (for CephFS)
# ===========================================================================

[mds]

# MDS cache memory limit. Controls how much RAM the MDS uses for the
# directory/inode cache. Larger caches improve metadata performance for
# workloads with many files.
# Default: 4294967296 (4 GB)  |  Recommended: 4 GB for most deployments
# Change when: CephFS workload has millions of files in active use (raise)
#   or the MDS host has limited RAM (lower, minimum ~1 GB).
#   Runtime: ceph config set mds mds_cache_memory_limit <bytes>
# mds_cache_memory_limit = 4294967296

# Number of active MDS ranks. Determines metadata parallelism for CephFS.
# Additional ranks beyond 1 split the directory tree for parallel serving.
# Default: 1  |  Recommended: 1 for most workloads
# Change when: metadata throughput is a bottleneck (many small file ops).
#   Managed via: ceph fs set <fsname> max_mds <N>
# max_mds = 1

# Number of standby MDS daemons for failover.
# Default: 0  |  Recommended: 1 (for HA; instant failover when active MDS dies)
# Change when: deploying CephFS in production — always have at least 1 standby.
#   Managed via: ceph orch apply mds <fsname> --placement="<count> <hosts>"
# mds_standby_count_wanted = 1

# ===========================================================================
# [client] — Client-side settings
# ===========================================================================

[client]

# RBD cache. Enables write-back caching in the librbd client for block devices.
# Default: true  |  Recommended: true
# Change when: you need strict write-through behavior (set to false) for
#   applications that bypass fsync and rely on immediate persistence.
# rbd_cache = true

# Maximum RBD write-back cache size per image (bytes).
# Default: 33554432 (32 MB)  |  Recommended: 32 MB
# Change when: workloads benefit from larger write coalescing (raise) or
#   you need to limit client memory usage (lower).
# rbd_cache_size = 33554432

# Maximum dirty (unwritten) data in the RBD cache before flushing.
# Default: 25165824 (24 MB)  |  Recommended: 24 MB
# Change when: raising rbd_cache_size — keep max_dirty at ~75% of cache_size.
# rbd_cache_max_dirty = 25165824

# Target dirty data level at which background flushing begins.
# Default: 16777216 (16 MB)  |  Recommended: 16 MB
# rbd_cache_target_dirty = 16777216

# Admin socket directory for client processes. Allows runtime introspection.
# Default: /var/run/ceph  |  Recommended: /var/run/ceph
# admin_socket = /var/run/ceph/$cluster-$type.$id.$pid.$cctid.asok

# Client-side log file. Useful for debugging RBD or CephFS client issues.
# Default: /var/log/ceph/ceph-client.$id.log
# Change when: you want client logs in a different location.
# log_file = /var/log/ceph/ceph-client.$id.log
