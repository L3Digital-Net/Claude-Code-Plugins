# Annotated falco.yaml
# Each directive includes: what it does, default value, and when to change it.
# Place this file at /etc/falco/falco.yaml (package default).
#
# After changes: sudo systemctl restart falco-modern-bpf
# Hot reload: automatic when watch_config_files is true (default), or
#   send SIGHUP to the process.
# Override individual options at the CLI: falco -o key=value
# Drop-in overrides: place YAML files in /etc/falco/config.d/ (merged at
#   root key level only; nested keys are replaced wholesale).
# Validate rules: falco -V /path/to/rules.yaml

# ===========================================================================
# RULES FILES
# ===========================================================================

# Ordered list of rule files and directories to load. Files load in order;
# later files can override macros, lists, and rules from earlier files.
# Directories load all .yaml files inside them alphabetically.
# Default: [/etc/falco/falco_rules.yaml, /etc/falco/falco_rules.local.yaml,
#           /etc/falco/rules.d]
# Change when: adding custom rule files or disabling upstream defaults.
# NOTE: never edit falco_rules.yaml directly; it gets overwritten on upgrade.
#   Put all customizations in falco_rules.local.yaml or rules.d/.
rules_files:
  - /etc/falco/falco_rules.yaml
  - /etc/falco/falco_rules.local.yaml
  - /etc/falco/rules.d

# ===========================================================================
# PLUGINS
# ===========================================================================

# Plugin definitions. Each entry registers a plugin that Falco can load.
# Registering a plugin here does NOT load it; add its name to load_plugins.
# Default: pre-configured entries for k8saudit, cloudtrail, json
# Change when: adding new plugins (e.g., okta, github) or changing
#   plugin open_params (e.g., the k8saudit webhook listen port).
plugins:
  - name: k8saudit
    library_path: libk8saudit.so
    init_config: ""
    open_params: "http://:9765/k8s-audit"
  - name: cloudtrail
    library_path: libcloudtrail.so
  - name: json
    library_path: libjson.so

# Which registered plugins to actually load at startup. Plugins not in this
# list are ignored even if defined above.
# Default: [] (no plugins loaded; syscall-based rules only)
# Change when: you want to process k8saudit, cloudtrail, or other plugin
#   event sources.
load_plugins: []

# ===========================================================================
# CONFIGURATION RELOAD
# ===========================================================================

# Watch rules files and config for changes, and reload automatically
# without restarting the service. Falco uses inotify to detect modifications.
# Default: true  |  Change when: you prefer explicit restarts for
#   change control, or inotify is unreliable (e.g., NFS-mounted configs).
watch_config_files: true

# Additional config files to merge. Placed in a directory, these files
# are merged at root key level with the main falco.yaml.
# Default: [/etc/falco/config.d]  |  Change when: using a different
#   overlay directory for environment-specific overrides.
# config_files:
#   - /etc/falco/config.d

# ===========================================================================
# OUTPUT FORMATTING
# ===========================================================================

# Use ISO 8601 timestamps (e.g., 2026-03-14T10:30:00+0000) in alert output
# instead of the default human-readable format.
# Default: false  |  Change when: parsing alerts with tools that expect
#   ISO 8601, or when operating across multiple timezones.
time_format_iso_8601: false

# Emit all alerts and rule validation output as JSON objects. Required for
# Falcosidekick and most log aggregation pipelines.
# Default: false  |  Change when: forwarding alerts to Falcosidekick,
#   Elasticsearch, or any JSON-consuming system.
json_output: false

# Include the human-readable "output" string property in JSON output.
# When true, the JSON includes both structured fields and the formatted
# output string. Disable to reduce payload size if consumers parse fields
# directly.
# Default: true  |  Change when: you only need structured fields in JSON
#   and want smaller payloads.
json_include_output_property: true

# Include the formatted rule output message without timestamp and priority.
# Default: false  |  Change when: downstream systems want a clean message
#   field without duplicating timestamp/priority already in other fields.
# json_include_message_property: false

# Include rule tags in JSON output as a "tags" array.
# Default: true  |  Change when: tags aren't needed downstream and you
#   want to reduce payload size.
json_include_tags_property: true

# ===========================================================================
# LOGGING (Falco process logs, not alert output)
# ===========================================================================

# Send Falco's own operational logs (startup, shutdown, errors) to stderr.
# These are process lifecycle logs, not security alerts.
# Default: true  |  Change when: running under a service manager that
#   already captures stderr (systemd does this by default).
log_stderr: true

# Send Falco's operational logs to syslog.
# Default: true  |  Change when: you don't want Falco logs mixed into
#   syslog, or you rely solely on journald.
log_syslog: true

# Minimum severity for Falco's own operational logs.
# Valid values: emergency, alert, critical, error, warning, notice, info, debug
# Default: "info"  |  Change when: debugging Falco itself (use "debug")
#   or reducing operational log noise (use "warning").
log_level: info

# Logging from Falco's underlying libs (libsinsp/libscap).
# Enable to see driver-level and event-parsing debug output.
# Default: enabled=false, severity=debug
# Change when: debugging driver loading issues or syscall capture problems.
# libs_logger:
#   enabled: false
#   severity: debug

# ===========================================================================
# ALERT PRIORITY AND BUFFERING
# ===========================================================================

# Minimum rule priority level to load and evaluate. Rules with a lower
# priority (higher verbosity) are ignored entirely, saving CPU.
# Valid values (highest to lowest): emergency, alert, critical, error,
#   warning, notice, informational, debug
# Default: "debug" (all rules loaded)  |  Change when: production
#   environments should use "notice" or "warning" to filter out
#   informational/debug rules that generate high event volume.
priority: debug

# Buffer alert output. When false, each alert is written immediately.
# When true, alerts are batched, which improves throughput but may delay
# delivery slightly.
# Default: false  |  Change when: high alert volume causes I/O bottlenecks.
buffered_outputs: false

# Rule matching strategy. "first" stops after the first matching rule per
# event; "all" evaluates every rule (slower but catches overlapping rules).
# Default: "first"  |  Change when: you have overlapping rules and need
#   all matches reported.
# rule_matching: first

# Maximum items in the output queue. 0 means unbounded (alerts never dropped,
# but memory can grow under sustained load).
# Default: 0  |  Change when: you want to cap memory usage by dropping
#   the oldest alerts when the queue is full.
# outputs_queue:
#   capacity: 0

# ===========================================================================
# SYSCALL EVENT DROP HANDLING
# ===========================================================================

# When the kernel generates syscall events faster than Falco can consume
# them, events are dropped. These settings control how Falco responds.
syscall_event_drops:

  # Percentage of events dropped (0.0 to 1.0) that triggers the configured
  # actions. At 0.1, actions fire when 10% or more events are dropped.
  # Default: 0.1  |  Change when: you want more or less sensitivity to
  #   drops. Lower values alert sooner.
  threshold: .1

  # What to do when drops exceed the threshold.
  # Valid actions: "ignore", "log", "alert", "exit"
  #   "log"   - write a message to Falco's operational log
  #   "alert" - emit a Falco alert (appears in all enabled output channels)
  #   "exit"  - terminate Falco (use for environments where incomplete
  #             monitoring is unacceptable)
  # Default: [log, alert]  |  Change when: you want Falco to exit on drops
  #   (critical security monitoring), or you want to suppress the noise.
  actions:
    - log
    - alert

  # Rate limit for drop notification messages, in messages per second.
  # 0.03333 = approximately one message every 30 seconds.
  # Default: 0.03333  |  Change when: drop messages are too noisy (lower
  #   the rate) or you need faster notification (raise it).
  rate: .03333

  # Maximum burst of drop messages allowed above the rate limit.
  # Default: 1  |  Change when: you want to allow a short burst of
  #   notifications when drops first begin.
  max_burst: 1

  # Simulate syscall event drops for testing. When true, Falco generates
  # fake drop events so you can verify your alerting pipeline handles them.
  # Default: false  |  Change when: testing drop alerting in a lab.
  # simulate_drops: false

# ===========================================================================
# OUTPUT TIMEOUT
# ===========================================================================

# Maximum time in milliseconds to wait for an output channel to accept an
# alert before considering it stalled. Applies to all output channels.
# Default: 2000  |  Change when: slow output destinations (e.g., remote
#   HTTP endpoints) need more time, or you want faster failure detection.
output_timeout: 2000

# ===========================================================================
# OUTPUT CHANNELS
# ===========================================================================

# --- stdout ---
# Write alerts to standard output. Useful for foreground testing and when
# running under a service manager that captures stdout (Docker, systemd).
# Default: enabled=true
# Change when: running as a daemon where stdout goes nowhere.
stdout_output:
  enabled: true

# --- syslog ---
# Write alerts to syslog. Alerts appear with the "falco" identifier.
# Default: enabled=true
# Change when: you don't use syslog for security events, or you forward
#   alerts exclusively via HTTP/Falcosidekick.
syslog_output:
  enabled: true

# --- file ---
# Write alerts to a file on disk.
# Default: enabled=false, keep_alive=false, filename=./events.txt
# keep_alive: when true, the file is kept open between alerts (better
#   performance). When false, the file is opened and closed per alert
#   (safer with log rotation).
# Change when: you want a persistent local alert log.
file_output:
  enabled: false
  keep_alive: false
  filename: ./events.txt

# --- program ---
# Pipe each alert to an external program's stdin. The program string is
# executed via a shell (/bin/sh -c). Classic use case: pipe JSON to curl
# for Slack webhooks.
# Default: enabled=false, keep_alive=false
# keep_alive: when true, the program stays running and receives alerts on
#   its stdin continuously. When false, the program is spawned per alert.
# Change when: you need custom alert processing without Falcosidekick.
program_output:
  enabled: false
  keep_alive: false
  program: "jq '{text: .output}' | curl -d @- -X POST https://hooks.slack.com/services/XXX"

# --- http ---
# POST alerts as JSON to an HTTP(S) endpoint. This is the primary
# integration point for Falcosidekick (default port 2801).
# Default: enabled=false
# Change when: deploying Falcosidekick or any HTTP-based alert receiver.
http_output:
  enabled: false
  url: "http://localhost:2801"

  # User-Agent header sent with HTTP requests.
  # Default: "falcosecurity/falco"
  user_agent: "falcosecurity/falco"

  # Skip TLS certificate verification for HTTPS endpoints. Not recommended
  # in production.
  # Default: false
  insecure: false

  # Path to CA certificate for verifying the remote server.
  # Default: "" (uses system CA store)
  # ca_cert: ""

  # Path to CA bundle directory.
  # Default: "/etc/ssl/certs"
  # ca_path: "/etc/ssl/certs"

  # Enable mutual TLS (mTLS) for the HTTP output connection.
  # Default: false
  # mtls: false
  # client_cert: "/etc/ssl/certs/client.crt"
  # client_key: "/etc/ssl/certs/client.key"

  # Compress the HTTP payload with gzip.
  # Default: false  |  Change when: sending large volumes of alerts over
  #   a bandwidth-constrained link.
  compress_uploads: false

  # Reuse the HTTP connection between alerts (HTTP keep-alive).
  # Default: false  |  Change when: high alert volume benefits from
  #   connection reuse.
  keep_alive: false

# ===========================================================================
# gRPC SERVER (DEPRECATED in v0.43.0)
# ===========================================================================

# The embedded gRPC server and grpc_output are deprecated since Falco 0.43.0
# and will be removed in a future release. Using them produces a deprecation
# warning. Migrate to http_output with Falcosidekick instead.

# gRPC server settings. When enabled, Falco exposes a gRPC API for
# streaming alerts and version information.
# Default: enabled=false
grpc:
  enabled: false

  # Bind address. Supports Unix sockets (unix:///path) and TCP (0.0.0.0:5060).
  # Unix sockets are faster and avoid network overhead for local consumers.
  # Default: "unix:///run/falco/falco.sock"
  bind_address: "unix:///run/falco/falco.sock"

  # Number of threads serving gRPC requests. 0 means auto (typically 1).
  # Default: 0  |  Change when: multiple concurrent gRPC clients need
  #   parallel handling.
  threadiness: 0

  # mTLS settings for gRPC (uncomment all three for mutual TLS).
  # private_key: "/etc/falco/certs/server.key"
  # cert_chain: "/etc/falco/certs/server.crt"
  # root_certs: "/etc/falco/certs/ca.crt"

# gRPC output. When enabled, Falco stores alerts in an in-memory ring
# buffer that gRPC clients consume via the streaming API.
# Default: enabled=false
# DEPRECATED: use http_output + Falcosidekick instead.
grpc_output:
  enabled: false

# ===========================================================================
# WEBSERVER
# ===========================================================================

# Embedded HTTP server for health checks and Prometheus metrics.
# Kubernetes uses the healthz endpoint for liveness probes.
webserver:

  # Enable the embedded webserver.
  # Default: true  |  Change when: you don't need health checks or metrics
  #   and want to reduce the attack surface.
  enabled: true

  # Port to listen on. The webserver binds on listen_address:listen_port.
  # Default: 8765  |  Change when: port 8765 conflicts with another service.
  listen_port: 8765

  # Address to bind. 0.0.0.0 listens on all interfaces.
  # Default: "0.0.0.0"  |  Change when: restricting to localhost or a
  #   specific interface.
  listen_address: 0.0.0.0

  # Health check endpoint path. Returns {"status":"ok"} when Falco is
  # healthy. Used by Kubernetes liveness probes.
  # Default: "/healthz"  |  Change when: your probe expects a different path.
  k8s_healthz_endpoint: /healthz

  # Number of threads for the webserver. 0 means auto.
  # Default: 0  |  Change when: high Prometheus scrape frequency or many
  #   concurrent health check requests.
  threadiness: 0

  # Expose Prometheus metrics at /metrics on the webserver port.
  # Default: false  |  Change when: scraping Falco metrics with Prometheus.
  prometheus_metrics_enabled: false

  # Enable SSL/TLS for the webserver.
  # Default: false  |  Change when: the health/metrics endpoint is exposed
  #   over an untrusted network.
  ssl_enabled: false

  # Path to a PEM file containing both the SSL certificate and private key
  # (concatenated). Required when ssl_enabled is true.
  # Default: "/etc/falco/falco.pem"
  ssl_certificate: /etc/falco/falco.pem

# ===========================================================================
# ENGINE (driver selection)
# ===========================================================================

# Syscall capture driver. Determines how Falco intercepts kernel events.
# Default: kind=modern_ebpf (since v0.38.0)
# Valid values: modern_ebpf, ebpf (deprecated in v0.43.0), kmod
# Change when: kernel is too old for modern_ebpf (requires >= 5.8).
# engine:
#   kind: modern_ebpf
#   modern_ebpf:
#     cpus_for_each_buffer: 2    # CPUs sharing each ring buffer (default: 2)
#     buf_size_preset: 4         # Buffer size index 0-9 (4 = 8 MB per CPU)

# ===========================================================================
# CONTAINER ENGINES
# ===========================================================================

# Container runtime sockets for enriching syscall events with container
# metadata (container.id, container.name, container.image.repository, and
# Kubernetes fields). Without a working socket, these fields resolve to <NA>.
# container_engines:
#   docker:
#     enabled: true
#   cri:
#     enabled: true
#     sockets:
#       - /run/containerd/containerd.sock
#       - /run/crio/crio.sock
#   podman:
#     enabled: true
#   lxc:
#     enabled: true
#   libvirt_lxc:
#     enabled: true

# ===========================================================================
# ADVANCED TUNING
# ===========================================================================

# Maximum consecutive syscall event timeouts before Falco takes action.
# Default: 1000  |  Change when: noisy environments trigger timeouts
#   frequently and you want more tolerance.
# syscall_event_timeouts:
#   max_consecutives: 1000

# Custom syscall set to monitor. When empty, Falco determines the minimum
# set from loaded rules (adaptive sinsp). Setting a custom_set overrides
# this and monitors only the listed syscalls.
# Default: custom_set=[], repair=false
# repair: when true, Falco adds any syscalls required by loaded rules that
#   are missing from custom_set (safety net against misconfiguration).
# base_syscalls:
#   custom_set: []
#   repair: false

# Thread table size for the kernel event processor.
# Default: 262144  |  Change when: monitoring hosts with more than 262K
#   concurrent threads (rare outside large container platforms).
# falco_libs:
#   thread_table_size: 262144
