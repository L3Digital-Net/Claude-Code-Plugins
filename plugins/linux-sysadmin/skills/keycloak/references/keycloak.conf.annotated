# Annotated keycloak.conf
# Each directive includes: what it does, default value, recommended value,
# and when to change it. Directives marked [build-time] require
# `bin/kc.sh build` before taking effect; all others are runtime options.
#
# Config precedence (highest to lowest):
#   1. CLI arguments (--db-username=admin)
#   2. Environment variables (KC_DB_USERNAME=admin)
#   3. conf/keycloak.conf (this file)
#   4. conf/keycloak.conf in the distribution archive
#
# After editing, restart Keycloak for runtime options, or run
#   bin/kc.sh build && bin/kc.sh start --optimized
# for any build-time changes.

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------

# Database vendor. Determines the JDBC driver and default URL pattern.
# Default: dev-file (H2 file)  |  Recommended: postgres for production
# Accepted: dev-file, dev-mem, mariadb, mssql, mysql, oracle, postgres, tidb
# [build-time] Change when: moving from dev mode to production. The dev-file
#   and dev-mem backends are unsuitable for any deployment beyond local testing.
db=postgres

# Full JDBC URL. Overrides db-url-host, db-url-database, db-url-port, and
# db-url-properties when set. Each vendor has a default template, so you
# usually only need to set host/database/port individually.
# Default: vendor-dependent template  |  Recommended: set explicitly in production
# Change when: you need connection parameters not covered by the individual
#   db-url-* options (e.g., SSL mode, connection timeout).
# db-url=jdbc:postgresql://localhost:5432/keycloak

# Hostname portion of the JDBC URL.
# Default: localhost  |  Recommended: your database hostname or IP
# Change when: the database runs on a separate host.
db-url-host=localhost

# Database name portion of the JDBC URL.
# Default: keycloak  |  Recommended: keycloak
# Change when: you use a different database name.
db-url-database=keycloak

# Port portion of the JDBC URL.
# Default: vendor-dependent (5432 for postgres)  |  Recommended: keep default
# Change when: your database listens on a non-standard port.
# db-url-port=5432

# Additional JDBC connection properties appended to the URL.
# Default: not set  |  Recommended: set for SSL or custom connection params
# Change when: you need to pass driver-specific parameters (e.g., sslmode=verify-full).
# db-url-properties=?sslmode=verify-full&sslrootcert=/etc/ssl/certs/ca.pem

# Database user credentials.
# Default: not set  |  Recommended: always set in production
# Change when: initial setup. Use KC_DB_USERNAME / KC_DB_PASSWORD env vars
#   to avoid storing credentials in the config file.
db-username=keycloak
db-password=changeme

# Database schema name. Relevant for databases that support multiple schemas
# within a single database (PostgreSQL, Oracle, MSSQL).
# Default: not set (uses the vendor default schema)
# Change when: you want Keycloak tables in a dedicated schema for isolation.
# db-schema=keycloak

# Connection pool sizing. Keycloak uses Agroal for connection pooling.
# Initial pool size: connections created at startup.
# Default: not set (defers to pool-min-size)  |  Recommended: leave unset
# db-pool-initial-size=0

# Minimum connections maintained in the pool.
# Default: not set (Agroal default)  |  Recommended: leave unset unless tuning
# db-pool-min-size=0

# Maximum connections in the pool.
# Default: 100  |  Recommended: 100 for most deployments
# Change when: you observe connection exhaustion under load. Monitor with
#   metrics-enabled=true and check the agroal_* metrics.
db-pool-max-size=100

# ---------------------------------------------------------------------------
# HOSTNAME
# ---------------------------------------------------------------------------

# The public URL at which Keycloak is reachable. Sets the base URL for all
# frontend requests, token issuers, and OIDC discovery endpoints.
# Default: not set  |  Recommended: always set in production
# Accepts a full URL (https://auth.example.com) or just a hostname
#   (auth.example.com, which implies https on port 8443).
# Change when: deploying behind a reverse proxy or to a public domain.
hostname=https://auth.example.com

# Disables dynamic hostname resolution from request headers.
# Default: true  |  Recommended: true for production (locks hostname to the
#   value above); false only for dev/testing with varying hostnames.
# Change when: you access Keycloak from multiple hostnames during development.
hostname-strict=true

# Separate URL for the admin console. Allows restricting admin access to an
# internal network while the public hostname serves end-user flows.
# Default: not set (uses hostname)  |  Recommended: set for internal admin access
# Change when: you want admin console access only from an internal URL.
# hostname-admin=https://admin.internal.example.com

# Enables dynamic resolution of backchannel URLs (token, userinfo, JWKS
# endpoints) from the request, instead of using the configured hostname.
# Default: false  |  Recommended: false (use explicit hostname)
# Change when: backchannel requests come from a different network than
#   frontend requests and need a different base URL.
# hostname-backchannel-dynamic=false

# Toggles the hostname debug page at /realms/master/hostname-debug.
# Default: false  |  Recommended: false in production
# Change when: debugging hostname resolution issues.
# hostname-debug=false

# ---------------------------------------------------------------------------
# HTTP / HTTPS
# ---------------------------------------------------------------------------

# Enables the HTTP listener. In production, Keycloak defaults to HTTPS-only.
# Default: false  |  Recommended: false (terminate TLS at Keycloak or proxy)
# Change when: running behind a TLS-terminating reverse proxy where the
#   proxy-to-Keycloak link is trusted (e.g., same host or private network).
http-enabled=false

# Interface the HTTP listener binds to.
# Default: 0.0.0.0  |  Recommended: 0.0.0.0 (all interfaces)
# Change when: restricting to a specific interface for security.
# http-host=0.0.0.0

# HTTP port for the main server listener.
# Default: 8080  |  Recommended: 8080
# Change when: the default port conflicts with another service.
http-port=8080

# HTTPS port for the main server listener.
# Default: 8443  |  Recommended: 8443
# Change when: a different HTTPS port is required.
https-port=8443

# PEM-format certificate and private key for HTTPS. Use these OR the
# keystore options below, not both.
# Default: not set  |  Recommended: use PEM files for simplicity
# Change when: setting up HTTPS for production.
# https-certificate-file=/etc/keycloak/tls/tls.crt
# https-certificate-key-file=/etc/keycloak/tls/tls.key

# Java keystore for HTTPS. Alternative to PEM files above.
# Default: not set  |  Recommended: use PEM files instead unless existing
#   infrastructure requires JKS/PKCS12.
# https-key-store-file=/etc/keycloak/tls/keystore.p12

# Keystore password.
# Default: password  |  Recommended: change from default in production
# https-key-store-password=password

# Keystore type (JKS, PKCS12, etc.).
# Default: auto-detected from file extension  |  Recommended: PKCS12
# https-key-store-type=PKCS12

# ---------------------------------------------------------------------------
# PROXY
# ---------------------------------------------------------------------------

# Which proxy header standard Keycloak trusts for client IP and protocol.
# Keycloak uses these headers to determine the original request scheme
# (http vs https) and client address.
# Default: not set (no proxy headers trusted)
# Accepted: forwarded (RFC 7239 Forwarded header), xforwarded (X-Forwarded-* headers)
# Recommended: xforwarded (most reverse proxies use X-Forwarded-*)
# Change when: deploying behind any reverse proxy. Without this setting,
#   Keycloak cannot detect HTTPS and will generate incorrect redirect URIs.
proxy-headers=xforwarded

# Restricts which source IPs may set trusted proxy headers. Accepts
# comma-separated IP addresses or CIDR ranges.
# Default: all addresses trusted  |  Recommended: restrict to proxy IPs
# Change when: you want to prevent header spoofing from non-proxy sources.
# proxy-trusted-addresses=10.0.0.0/8,192.168.1.100

# ---------------------------------------------------------------------------
# FEATURES
# ---------------------------------------------------------------------------

# Enables optional Keycloak features. Comma-separated list.
# Default: not set (only default features enabled)
# [build-time] Common features: docker, admin-fine-grained-authz, dpop,
#   client-secret-rotation, organization, passkeys, token-exchange, multi-site
# Change when: you need functionality beyond the default feature set.
#   Run `bin/kc.sh build --features=<list>` then restart.
# features=docker,token-exchange

# ---------------------------------------------------------------------------
# METRICS AND HEALTH
# ---------------------------------------------------------------------------

# Exposes Prometheus-format metrics on the management port (default 9000).
# Default: false  |  Recommended: true for production (monitor with Prometheus/Grafana)
# [build-time] Metrics endpoint: http://<host>:9000/metrics
# Change when: setting up monitoring infrastructure.
metrics-enabled=true

# Exposes health check endpoints on the management port (default 9000):
#   /health, /health/live, /health/ready, /health/started
# Default: false  |  Recommended: true for production and container orchestration
# [build-time] Health endpoints return HTTP 200 (healthy) or 503 (unhealthy).
# Change when: using Kubernetes probes or any load balancer health checks.
health-enabled=true

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------

# Log handler(s) to enable. Comma-separated list.
# Default: console  |  Accepted: console, file, syslog
# Recommended: console (systemd/container captures stdout to journald)
# Change when: you need file-based logging alongside console output.
log=console

# Root log level. Can include per-category overrides separated by commas.
# Default: info  |  Accepted: off, fatal, error, warn, info, debug, trace, all
# Recommended: info for production; warn for high-volume deployments
# Change when: debugging issues (use debug or trace), or reducing log noise.
# Per-category example: info,org.keycloak.events:debug,org.hibernate.SQL:debug
log-level=info

# Console output format.
# Default: default (unstructured text)  |  Accepted: default, json
# Recommended: json when feeding logs to a log aggregator (ELK, Loki)
# Change when: you use structured log pipelines.
# log-console-output=default

# Console log entry format (only applies when log-console-output=default).
# Default: %d{yyyy-MM-dd HH:mm:ss,SSS} %-5p [%c] (%t) %s%e%n
# Change when: you need different timestamp formats or additional fields.
# log-console-format=%d{yyyy-MM-dd HH:mm:ss,SSS} %-5p [%c] (%t) %s%e%n

# Log file path. Only used when log=file is included.
# Default: data/log/keycloak.log (relative to Keycloak install dir)
# Change when: you want logs in a standard system path.
# log-file=/var/log/keycloak/keycloak.log

# File output format.
# Default: default  |  Accepted: default, json
# log-file-output=default

# File log entry format (only applies when log-file-output=default).
# Default: %d{yyyy-MM-dd HH:mm:ss,SSS} %-5p [%c] (%t) %s%e%n
# log-file-format=%d{yyyy-MM-dd HH:mm:ss,SSS} %-5p [%c] (%t) %s%e%n

# Syslog output format. Only used when log=syslog is included.
# Default: default  |  Accepted: default, json
# log-syslog-output=default

# ---------------------------------------------------------------------------
# CACHE (INFINISPAN)
# ---------------------------------------------------------------------------

# Cache mechanism for high-availability. ispn = embedded Infinispan
# (clustered); local = local-only (single node, no replication).
# Default: ispn  |  Recommended: ispn for production clusters
# [build-time] Change when: running a single non-HA instance (use local).
cache=ispn

# Custom Infinispan configuration file. Overrides the built-in cache config.
# Default: not set (uses built-in conf/cache-ispn.xml)
# [build-time] Change when: tuning cache sizes, eviction, or persistence.
# cache-config-file=conf/cache-ispn.xml

# JGroups stack for cluster discovery and communication between Keycloak nodes.
# Default: jdbc-ping  |  Accepted: jdbc-ping, kubernetes (deprecated), custom
# [build-time] jdbc-ping uses the configured database for node discovery.
# Change when: deploying on Kubernetes (use DNS-based discovery) or custom stacks.
# cache-stack=jdbc-ping

# Encrypt communication between Keycloak cluster nodes using mutual TLS.
# Default: true  |  Recommended: true for production
# [build-time] Keycloak auto-generates and rotates mTLS certificates.
# cache-embedded-mtls-enabled=true

# External Infinispan cluster connection. Use for multi-site deployments
# where sessions are replicated across data centers.
# Default: not set  |  Recommended: set only for multi-site HA deployments
# cache-remote-host=infinispan.example.com
# cache-remote-port=11222
# cache-remote-username=keycloak
# cache-remote-password=changeme

# ---------------------------------------------------------------------------
# TRANSACTIONS
# ---------------------------------------------------------------------------

# Enable XA (two-phase commit) datasources. Required when the application
# needs distributed transactions across multiple resources.
# Default: false  |  Recommended: false (XA adds overhead; not needed for
#   standard Keycloak deployments)
# Change when: using a transaction manager that requires XA coordination.
# Note: Keycloak logs a "Transaction recovery warning" with XA enabled
#   unless a recovery module is configured. Safe to leave disabled.
transaction-xa-enabled=false

# ---------------------------------------------------------------------------
# SPI THEME
# ---------------------------------------------------------------------------

# Maximum age (in seconds) for caching static theme resources (CSS, JS, images)
# in browser caches. -1 disables caching entirely.
# Default: 2592000 (30 days)  |  Recommended: keep default for production
# Change when: developing themes — set to -1 to see changes immediately.
# spi-theme-static-max-age=2592000

# Cache compiled theme definitions in memory. Disabling forces Keycloak to
# reload theme metadata on every request.
# Default: true  |  Recommended: true for production
# Change when: developing themes — set to false for live reloading.
# spi-theme-cache-themes=true

# Cache compiled FreeMarker templates in memory. Disabling forces recompilation
# on every page render.
# Default: true  |  Recommended: true for production
# Change when: developing themes — set to false for live template editing.
# spi-theme-cache-templates=true

# Override the welcome page theme.
# Default: keycloak (built-in theme)
# Change when: you've created a custom welcome page theme.
# spi-theme-welcome-theme=custom-theme
