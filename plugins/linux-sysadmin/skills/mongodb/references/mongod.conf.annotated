# Annotated mongod.conf
# Each directive includes: what it does, default value, recommended production
# value, and when to change it.
#
# MongoDB reads this file at startup via: mongod --config /etc/mongod.conf
# Changes require a service restart: sudo systemctl restart mongod
# Default location: /etc/mongod.conf (installed by the mongodb-org package)
#
# Format: YAML (strict — spaces only, no tabs). Indentation errors cause mongod
# to refuse to start. Validate with: python3 -c "import yaml; yaml.safe_load(open('/etc/mongod.conf'))"

# ---------------------------------------------------------------------------
# SYSTEM LOG
# ---------------------------------------------------------------------------

systemLog:
  # Where to send log output.
  # Options: file (write to path below), syslog (send to syslog daemon)
  # Default: stdout when run in foreground
  # Recommended: file for package-managed installs (systemd captures stdout anyway,
  #   but file-based logging allows mongod's own log rotation and is the package default).
  destination: file

  # Log file path. Only used when destination is "file".
  # Default (Ubuntu/Debian): /var/log/mongodb/mongod.log
  # Default (RHEL): /var/log/mongodb/mongod.log
  # Change when: separating logs onto a dedicated volume.
  path: /var/log/mongodb/mongod.log

  # Append to the existing log file on restart instead of overwriting.
  # Default: false  |  Recommended: true
  # Set to false only if you want a clean log on every restart (unusual in production).
  logAppend: true

  # Log rotation method. Only applies when destination is "file".
  # Options: rename (mongod renames the file, then creates a new one),
  #          reopen (mongod closes and reopens the file — for external rotation tools like logrotate).
  # Default: rename  |  Recommended: reopen if using logrotate; rename otherwise.
  # To trigger rotation: db.adminCommand({ logRotate: 1 }) or send SIGUSR1 to mongod.
  # logRotate: rename

  # Verbosity level for diagnostic logging. 0 = informational (default).
  # Range: 0-5. Each level includes all messages from lower levels.
  # Default: 0  |  Recommended: 0 in production; 1-2 for debugging
  # Per-component verbosity is also available (e.g., systemLog.component.accessControl.verbosity).
  # verbosity: 0

# ---------------------------------------------------------------------------
# STORAGE
# ---------------------------------------------------------------------------

storage:
  # Directory where mongod stores data files and journal.
  # Default (Ubuntu/Debian): /var/lib/mongodb
  # Default (RHEL): /var/lib/mongo
  # Change when: placing data on a separate volume for I/O isolation.
  # The directory must exist and be owned by the mongodb user.
  dbPath: /var/lib/mongodb

  # Journal settings. WiredTiger journaling provides crash recovery.
  # journal:
    # Enable journaling. Enabled by default since MongoDB 4.0 for WiredTiger.
    # Default: true  |  Recommended: true — never disable in production.
    # Disabling forfeits crash recovery and prevents replica set membership.
    # enabled: true

  # WiredTiger storage engine settings.
  wiredTiger:
    engineConfig:
      # Maximum size of the WiredTiger internal cache.
      # Default: the larger of (50% of (total RAM - 1 GB)) or 256 MB.
      # Recommended: leave unset for dedicated single-instance hosts. Set explicitly
      #   for containers (Docker/LXC) and shared hosts, because mongod sees the
      #   host's total RAM, not the container's memory limit.
      # Never exceed 80% of available RAM. For a 4 GB container, set to 1.5.
      # cacheSizeGB: 1.5

      # Compression for journal files.
      # Options: none, snappy, zlib, zstd
      # Default: snappy  |  Recommended: snappy (good balance of CPU vs compression)
      # journalCompressor: snappy

    collectionConfig:
      # Default compression for collection data.
      # Options: none, snappy, zlib, zstd
      # Default: snappy  |  Recommended: zstd for better compression with similar CPU;
      #   snappy for lower CPU overhead on write-heavy workloads.
      # blockCompressor: snappy

    indexConfig:
      # Enable prefix compression for index entries.
      # Default: true  |  Recommended: true (reduces index size with minimal CPU cost)
      # prefixCompression: true

# ---------------------------------------------------------------------------
# NETWORK
# ---------------------------------------------------------------------------

net:
  # TCP port for mongod to listen on.
  # Default: 27017  |  Recommended: 27017 (change only for multiple instances on one host)
  port: 27017

  # IP addresses mongod binds to for incoming connections.
  # Default: 127.0.0.1 (localhost only)
  # Recommended: 127.0.0.1 for local-only; add specific IPs for remote access.
  # Use 0.0.0.0 to bind all interfaces (requires firewall protection).
  # Comma-separated list: "127.0.0.1,10.0.0.5"
  # CAUTION: changing this without enabling authentication exposes an unprotected
  #   database to the network. Always enable security.authorization with remote access.
  bindIp: 127.0.0.1

  # Maximum simultaneous connections mongod will accept.
  # Default: 65536 (or OS file descriptor limit minus reserved FDs)
  # Recommended: leave at default unless you need to limit connections.
  # maxIncomingConnections: 65536

  # TLS/SSL settings for encrypted connections.
  # tls:
    # TLS mode. Options: disabled, allowTLS, preferTLS, requireTLS
    # Default: disabled  |  Recommended: requireTLS for production clusters
    # mode: disabled

    # Path to the PEM file containing the TLS certificate and key.
    # certificateKeyFile: /etc/ssl/mongodb.pem

    # Path to the CA file for validating client certificates.
    # CAFile: /etc/ssl/ca.pem

# ---------------------------------------------------------------------------
# SECURITY
# ---------------------------------------------------------------------------

security:
  # Enable role-based access control (RBAC).
  # Default: disabled  |  Recommended: enabled for any non-development deployment
  # When enabled, clients must authenticate. Create an admin user BEFORE enabling,
  # or use the localhost exception (first connection from localhost can create users).
  # authorization: enabled

  # Path to the keyfile for internal authentication between replica set members.
  # The keyfile must be owned by the mongodb user with mode 0400.
  # Required for: replica sets and sharded clusters with auth enabled.
  # Generate: openssl rand -base64 756 > /etc/mongodb-keyfile && chmod 400 /etc/mongodb-keyfile
  # Enabling keyFile implicitly enables authorization.
  # keyFile: /etc/mongodb-keyfile

# ---------------------------------------------------------------------------
# OPERATION PROFILING
# ---------------------------------------------------------------------------

operationProfiling:
  # Profiling level for slow operations.
  # Options: off, slowOp (log slow ops), all (log everything — very high volume)
  # Default: off  |  Recommended: slowOp in production
  # mode: slowOp

  # Threshold in milliseconds for a "slow" operation.
  # Default: 100  |  Recommended: 100 (lower to 50 for latency-sensitive apps)
  # Operations exceeding this are logged and added to system.profile.
  # slowOpThresholdMs: 100

# ---------------------------------------------------------------------------
# REPLICATION
# ---------------------------------------------------------------------------

replication:
  # Name of the replica set this mongod belongs to.
  # Default: none (standalone)  |  Set when: creating or joining a replica set.
  # All members of a replica set must use the same replSetName.
  # Enabling this on a standalone effectively converts it; run rs.initiate() after restart.
  # replSetName: myReplicaSet

  # Size of the oplog in megabytes. The oplog is a capped collection that records
  # all write operations for replication.
  # Default: 5% of free disk space (minimum 990 MB, maximum 50 GB)
  # Recommended: large enough to hold 24-72 hours of writes for maintenance windows.
  # Check current usage: rs.printReplicationInfo()
  # oplogSizeMB: 2048

# ---------------------------------------------------------------------------
# SHARDING
# ---------------------------------------------------------------------------

sharding:
  # Role of this mongod in a sharded cluster.
  # Options: configsvr (config server, listens on 27019), shardsvr (shard, listens on 27018)
  # Default: none (not part of a sharded cluster)
  # Set when: deploying a sharded cluster. Config servers store cluster metadata;
  # shard servers store actual data chunks.
  # clusterRole: shardsvr

# ---------------------------------------------------------------------------
# PROCESS MANAGEMENT
# ---------------------------------------------------------------------------

processManagement:
  # Time zone used for log timestamps.
  # Options: local, UTC
  # Default: local  |  Recommended: UTC for consistent timestamps across time zones
  # timeZoneInfo: /usr/share/zoneinfo

  # Run mongod as a background daemon (fork).
  # Default: false  |  Recommended: false when managed by systemd (systemd handles forking)
  # Set to true only when starting mongod manually without a service manager.
  # fork: false

# ---------------------------------------------------------------------------
# SET PARAMETER (runtime-tunable settings)
# ---------------------------------------------------------------------------

# setParameter:
  # Authentication mechanisms the server accepts.
  # Default: SCRAM-SHA-1,SCRAM-SHA-256
  # Recommended: SCRAM-SHA-256 only for new deployments.
  # authenticationMechanisms: SCRAM-SHA-256

  # Enable background auto-compaction (MongoDB 8.0+).
  # Keeps free space in collections and indexes below freeSpaceTargetMB.
  # autoCompact: true
